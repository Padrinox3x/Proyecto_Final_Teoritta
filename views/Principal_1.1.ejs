<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>CRUD Productos</title>
<link rel="stylesheet" href="/css/Principal_1.1.css">
<link rel="stylesheet" href="/css/breadcrums.css"> 
</head>

<body>

    <%- include('partials/breadcrumb') %>
 
<div class="top-bar">
    <input type="text" id="search" placeholder="Buscar...">
    
    <select id="rows">
        <option value="5">5</option>
        <option value="10" selected>10</option>
        <option value="15">15</option>
    </select>

    <button class="btn-add" onclick="openModal()">+</button>
</div>

<table>
<thead>
<tr>
    <th>Nombre Producto</th>
    <th>Categoría</th>
    <th>Stock</th>
    <th>Fecha Caducidad</th>
    <th>Acciones</th>
</tr>
</thead>
<tbody id="tableBody"></tbody>
</table>

<div class="pagination">
    <button onclick="firstPage()">⏮</button>
    <button onclick="prevPage()">◀</button>
    
    <span id="pageInfo"></span>
    
    <button onclick="nextPage()">▶</button>
    <button onclick="lastPage()">⏭</button>
</div>

<!-- MODAL -->
<div class="modal" id="modal">
    <div class="modal-content">
        <h3>Registrar Producto</h3>
        <input id="nombre" placeholder="Nombre Producto">
        <input id="categoria" placeholder="Categoría">
        <input id="stock" type="number" placeholder="Stock">
        <input id="fecha" type="date">
        
        <button onclick="save()">Guardar</button>
        <button onclick="closeModal()">Cancelar</button>
    </div>
</div>

<script src="/js/breadcrums.js"></script> 

<script>
let data = JSON.parse(localStorage.getItem("productos")) || [];
let page = 1;
let rows = 10;
let editIndex = null;

/* GUARDAR */
function persist(){
    localStorage.setItem("productos", JSON.stringify(data));
}

/* TOTAL PAGINAS */
function totalPages(filteredLength){
    return Math.ceil(filteredLength / rows) || 1;
}

/* FILTRO */
function getFilteredData(){
    let search = document.getElementById("search").value.toLowerCase();

    return data.filter(d =>
        d.nombre.toLowerCase().includes(search) ||
        d.categoria.toLowerCase().includes(search) ||
        d.stock.toString().includes(search) ||
        d.fecha.includes(search)
    );
}

/* RENDER */
function render(){
    let tbody = document.getElementById("tableBody");
    tbody.innerHTML = "";

    let filtered = getFilteredData();

    let start = (page-1)*rows;
    let paginated = filtered.slice(start, start+rows);

    paginated.forEach((d,i)=>{
        tbody.innerHTML += `
        <tr>
            <td>${d.nombre}</td>
            <td>${d.categoria}</td>
            <td>${d.stock}</td>
            <td>${d.fecha}</td>
            <td>
                <button class="btn-edit" onclick="edit(${start+i})">✏️</button>
                <button class="btn-delete" onclick="del(${start+i})">🗑</button>
            </td>
        </tr>`;
    });

    let total = totalPages(filtered.length);

    if(page > total) page = total;

    document.getElementById("pageInfo").innerText =
        "Página " + page + " de " + total;
}

/* PAGINACIÓN */
function nextPage(){
    let filtered = getFilteredData();
    if(page < totalPages(filtered.length)){
        page++;
        render();
    }
}

function prevPage(){
    if(page > 1){
        page--;
        render();
    }
}

function firstPage(){
    page = 1;
    render();
}

function lastPage(){
    let filtered = getFilteredData();
    page = totalPages(filtered.length);
    render();
}

/* FILAS */
document.getElementById("rows").addEventListener("change", e=>{
    rows = parseInt(e.target.value);
    page = 1;
    render();
});

/* BUSCAR */
document.getElementById("search").addEventListener("input", ()=>{
    page = 1;
    render();
});

/* MODAL */
function openModal(){
    document.getElementById("modal").style.display="flex";
}

function closeModal(){
    document.getElementById("modal").style.display="none";
    clear();
}

function clear(){
    document.getElementById("nombre").value="";
    document.getElementById("categoria").value="";
    document.getElementById("stock").value="";
    document.getElementById("fecha").value="";
    editIndex = null;
}

/* GUARDAR */
function save(){
    let obj = {
        nombre: document.getElementById("nombre").value,
        categoria: document.getElementById("categoria").value,
        stock: document.getElementById("stock").value,
        fecha: document.getElementById("fecha").value
    };

    if(editIndex !== null){
        data[editIndex] = obj;
    }else{
        data.push(obj);
    }

    persist();
    closeModal();
    render();
}

/* EDITAR */
function edit(i){
    let d = data[i];
    document.getElementById("nombre").value = d.nombre;
    document.getElementById("categoria").value = d.categoria;
    document.getElementById("stock").value = d.stock;
    document.getElementById("fecha").value = d.fecha;

    editIndex = i;
    openModal();
}

/* ELIMINAR */
function del(i){
    if(confirm("¿Eliminar producto?")){
        data.splice(i,1);
        persist();
        render();
    }
}

render();
</script>

</body>
</html>