<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>CRUD Empleados - Principal 2.2</title>
    <link rel="stylesheet" href="/css/Principal_1.1.css">
    <link rel="stylesheet" href="/css/breadcrums.css"> 

    <style>
        .pagination { margin-top: 15px; display: flex; gap: 10px; align-items: center; justify-content: center; }
        .pagination button { padding: 5px 12px; cursor: pointer; border: 1px solid #ccc; background: #fff; border-radius: 4px; }
        .pagination button:disabled { opacity: 0.5; cursor: not-allowed; }

        #btnNuevo { display: none; }

        .no-access {
            text-align: center;
            margin-top: 80px;
            color: #334155;
        }
    </style>
</head>

<body>

<%- include('partials/breadcrumb') %>

<div class="top-bar">
    <input type="text" id="search" placeholder="Buscar empleado...">
    
    <select id="rows">
        <option value="5">5</option>
        <option value="10" selected>10</option>
        <option value="15">15</option>
    </select>

    <button id="btnNuevo" class="btn-add" onclick="openModal()">+</button>
</div>

<table>
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Apellidos</th>
            <th>Teléfono</th>
            <th>Correo</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody id="tableBody"></tbody>
</table>

<div class="pagination">
    <button id="btnFirst" onclick="firstPage()">⏮</button>
    <button id="btnPrev" onclick="prevPage()">◀</button>
    <span id="pageInfo"></span>
    <button id="btnNext" onclick="nextPage()">▶</button>
    <button id="btnLast" onclick="lastPage()">⏭</button>
</div>

<div class="modal" id="modal" style="display: none;">
    <div class="modal-content">
        <h3 id="modalTitle">Registrar Empleado</h3>
        
        <label>Nombre</label>
        <input id="nombreProveedor" maxlength="50" oninput="this.value = this.value.replace(/[0-9]/g, '')">
        
        <label>Apellidos</label>
        <input id="ApellidosProveedor" maxlength="50" oninput="this.value = this.value.replace(/[0-9]/g, '')">
        
        <label>Correo</label>
        <input id="Correo" type="email">
        
        <label>Teléfono</label>
        <input id="Telefono" maxlength="15" oninput="this.value = this.value.replace(/[^0-9]/g, '')">
        
        <div class="acciones-modal">
            <button class="btn-save" onclick="save()">Guardar</button>
            <button class="btn-cancel" onclick="closeModal()">Cancelar</button>
        </div>
    </div>
</div>

<script src="/js/breadcrums.js"></script> 

<script>
// =========================
// DATOS
// =========================
let data = JSON.parse(localStorage.getItem("empleados_sucursal")) || [];
let page = 1;
let rows = 10;
let editIndex = null;

// =========================
// PERMISOS
// =========================
let permisosModulo = {
    bitAgregar: 0,
    bitEditar: 0,
    bitConsulta: 1, // 👈 SIEMPRE mínimo lectura
    bitEliminar: 0,
    bitDetalle: 0,
    bitAdministrador: 0 
};

// =========================
// CARGAR PERMISOS (ROBUSTO)
// =========================
async function cargarPermisos() {
    try {
        const res = await fetch('/api/permisosPerfil/mis-permisos?modulo=Principal_2.2');

        if (!res.ok) {
            console.warn("Sin permisos en BD → fallback lectura");
        } else {
            const result = await res.json();
            if (result) permisosModulo = result;
        }

    } catch (error) {
        console.error("Error permisos:", error);
    }

    // 🔒 VALIDAR ACCESO
    if (!(permisosModulo.bitAdministrador || permisosModulo.bitConsulta)) {
        document.body.innerHTML = `
            <div class="no-access">
                <h2>⛔ Acceso denegado</h2>
                <p>No tienes permisos para este módulo.</p>
            </div>
        `;
        return false;
    }

    // BOTÓN NUEVO
    const puedeAgregar = permisosModulo.bitAdministrador || permisosModulo.bitAgregar;
    const btn = document.getElementById('btnNuevo');
    if(btn) btn.style.display = puedeAgregar ? 'block' : 'none';

    return true;
}

// =========================
// STORAGE
// =========================
function persist(){
    localStorage.setItem("empleados_sucursal", JSON.stringify(data));
}

// =========================
// FILTRO
// =========================
function getFilteredData(){
    const search = (document.getElementById("search").value || "").toLowerCase();

    return data.filter(d =>
        (d.nombreProveedor || "").toLowerCase().includes(search) ||
        (d.apellidosProveedor || "").toLowerCase().includes(search) ||
        (d.correo || "").toLowerCase().includes(search) ||
        (d.telefono || "").toString().includes(search)
    );
}

// =========================
// RENDER
// =========================
function render(){

    if (!(permisosModulo.bitAdministrador || permisosModulo.bitConsulta)) return;

    const tbody = document.getElementById("tableBody");
    tbody.innerHTML = "";

    const filtered = getFilteredData();
    const total = Math.ceil(filtered.length / rows) || 1;

    if(page > total) page = total;

    const start = (page - 1) * rows;
    const paginated = filtered.slice(start, start + rows);

    paginated.forEach((d) => {

        const realIndex = data.indexOf(d);

        const puedeEditar = permisosModulo.bitAdministrador || permisosModulo.bitEditar;
        const puedeEliminar = permisosModulo.bitAdministrador || permisosModulo.bitEliminar;

        let acciones = "";

        if (puedeEditar) {
            acciones += `<button onclick="edit(${realIndex})">✏️</button> `;
        }

        if (puedeEliminar) {
            acciones += `<button onclick="del(${realIndex})">🗑</button>`;
        }

        if (!acciones) {
            acciones = `<span style="color:gray;">Solo lectura</span>`;
        }

        tbody.innerHTML += `
        <tr>
            <td>${d.nombreProveedor || ''}</td>
            <td>${d.apellidosProveedor || ''}</td>
            <td>${d.telefono || ''}</td>
            <td>${d.correo || ''}</td>
            <td>${acciones}</td>
        </tr>`;
    });

    document.getElementById("pageInfo").innerText = `Página ${page} de ${total}`;
}

// =========================
// PAGINACIÓN
// =========================
function firstPage(){ page=1; render(); }
function prevPage(){ if(page>1){ page--; render(); } }
function nextPage(){ 
    let total = Math.ceil(getFilteredData().length / rows) || 1;
    if(page<total){ page++; render(); } 
}
function lastPage(){ page = Math.ceil(getFilteredData().length / rows) || 1; render(); }

// =========================
// MODAL
// =========================
function openModal(){ document.getElementById("modal").style.display = "flex"; }

function closeModal(){
    document.getElementById("modal").style.display = "none";
    document.getElementById("nombreProveedor").value = "";
    document.getElementById("ApellidosProveedor").value = "";
    document.getElementById("Correo").value = "";
    document.getElementById("Telefono").value = "";
    editIndex = null;
}

// =========================
// CRUD
// =========================
function save(){

    const puedeEditar = permisosModulo.bitAdministrador || permisosModulo.bitEditar;
    const puedeAgregar = permisosModulo.bitAdministrador || permisosModulo.bitAgregar;

    if(editIndex !== null && !puedeEditar) return alert("❌ Sin permiso editar");
    if(editIndex === null && !puedeAgregar) return alert("❌ Sin permiso crear");

    const nombre = document.getElementById("nombreProveedor").value.trim();
    const apellidos = document.getElementById("ApellidosProveedor").value.trim();

    if(!nombre || !apellidos) return alert("Campos obligatorios");

    const obj = {
        nombreProveedor: nombre,
        apellidosProveedor: apellidos,
        correo: document.getElementById("Correo").value.trim(),
        telefono: document.getElementById("Telefono").value.trim()
    };

    if(editIndex !== null) data[editIndex] = obj;
    else data.push(obj);

    persist();
    closeModal();
    render();
}

function edit(i){
    if(!(permisosModulo.bitAdministrador || permisosModulo.bitEditar))
        return alert("❌ Sin permiso");

    editIndex = i;
    const d = data[i];

    document.getElementById("nombreProveedor").value = d.nombreProveedor;
    document.getElementById("ApellidosProveedor").value = d.apellidosProveedor;
    document.getElementById("Correo").value = d.correo;
    document.getElementById("Telefono").value = d.telefono;

    openModal();
}

function del(i){
    if(!(permisosModulo.bitAdministrador || permisosModulo.bitEliminar))
        return alert("❌ Sin permiso");

    if(confirm("¿Eliminar?")){
        data.splice(i,1);
        persist();
        render();
    }
}

// =========================
// EVENTOS
// =========================
document.getElementById("search").addEventListener("input", ()=>{ page=1; render(); });
document.getElementById("rows").addEventListener("change",(e)=>{ rows=parseInt(e.target.value); page=1; render(); });

// =========================
// INIT
// =========================
document.addEventListener("DOMContentLoaded", async () => {
    const acceso = await cargarPermisos();
    if (acceso) render();
});
</script>

</body>
</html>