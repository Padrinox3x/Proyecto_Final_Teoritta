<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>CRUD Productos</title>
    <link rel="stylesheet" href="/css/Principal_1.1.css">
    <link rel="stylesheet" href="/css/breadcrums.css"> 
</head>

<body>
    <%- include('partials/breadcrumb') %>
 
   <div class="top-bar">
        <input type="text" id="search" placeholder="Buscar producto o categoría...">
        
        <select id="rows">
            <option value="5">5</option>
            <option value="10" selected>10</option>
            <option value="15">15</option>
        </select>

        <button id="btnNuevo" class="btn-add" onclick="openModal()">+</button>
    </div>

<script src="/js/breadcrums.js"></script> 

    <script>
        let data = JSON.parse(localStorage.getItem("productos")) || [];
        let page = 1;
        let rows = 10;
        let editIndex = null;

        // --- 🛡️ ESTADO GLOBAL DE PERMISOS ---
        let permisosModulo = {
            bitAgregar: 0, bitEditar: 0, bitConsulta: 0, bitEliminar: 0, bitDetalle: 0
        };

        // --- 🛡️ CARGAR PERMISOS DESDE EL SERVIDOR ---
        async function cargarPermisos() {
            try {
                // Aquí usamos el nombre del archivo o módulo (Principal_1_1)
                const res = await fetch('/api/permisosPerfil/mis-permisos?modulo=Principal_1_1');
                permisosModulo = await res.json();
                
                // Ocultar botón "+" si no puede agregar
                if (!permisosModulo.bitAgregar) {
                    document.getElementById('btnNuevo').style.display = 'none';
                }
            } catch (error) {
                console.error("Error cargando permisos:", error);
            }
        }

        function persist(){
            localStorage.setItem("productos", JSON.stringify(data));
        }

        function totalPages(filteredLength){
            return Math.ceil(filteredLength / rows) || 1;
        }

        function getFilteredData(){
            let search = document.getElementById("search").value.toLowerCase();
            return data.filter(d =>
                d.nombre.toLowerCase().includes(search) ||
                d.categoria.toLowerCase().includes(search) ||
                d.stock.toString().includes(search) ||
                d.fecha.includes(search)
            );
        }

        function render(){
            let tbody = document.getElementById("tableBody");
            tbody.innerHTML = "";

            let filtered = getFilteredData();
            let start = (page-1)*rows;
            let paginated = filtered.slice(start, start+rows);

            paginated.forEach((d, i) => {
                let realIndex = data.indexOf(d);
                
                // --- 🛡️ LÓGICA DE BOTONES SEGÚN PERMISOS ---
                let btnEdit = permisosModulo.bitEditar 
                    ? `<button class='btn-edit' onclick='edit(${realIndex})'>✏️</button>` 
                    : "";
                
                let btnDel = permisosModulo.bitEliminar 
                    ? `<button class='btn-delete' onclick='del(${realIndex})'>🗑</button>` 
                    : "";

                if (!permisosModulo.bitEditar && !permisosModulo.bitEliminar) {
                    btnEdit = "<span style='color:gray;font-size:11px;'>Lectura</span>";
                }

                let row = `<tr>
                    <td>${d.nombre}</td>
                    <td>${d.categoria}</td>
                    <td>${d.stock}</td>
                    <td>${d.fecha}</td>
                    <td>${btnEdit} ${btnDel}</td>
                </tr>`;
                
                tbody.innerHTML += row;
            });

            let total = totalPages(filtered.length);
            if(page > total && total > 0) page = total;
            document.getElementById("pageInfo").innerText = "Página " + page + " de " + total;
        }

        // ... (Funciones de paginación y modal se mantienen igual) ...

        // 🛡️ MODIFICACIÓN EN SAVE: Verificar bit antes de procesar
        function save(){
            if(editIndex !== null && !permisosModulo.bitEditar){
                alert("❌ No tienes permiso para editar.");
                return;
            }
            if(editIndex === null && !permisosModulo.bitAgregar){
                alert("❌ No tienes permiso para agregar.");
                return;
            }

            const nombre = document.getElementById("nombre").value.trim();
            const categoria = document.getElementById("categoria").value.trim();
            const stock = document.getElementById("stock").value;
            const fecha = document.getElementById("fecha").value;

            if(!nombre || !categoria || !stock || !fecha){
                alert("❌ Todos los campos son obligatorios.");
                return;
            }

            const regexLetras = /^[A-Za-zÁ-ú\sñÑ]+$/;
            if(!regexLetras.test(nombre) || !regexLetras.test(categoria)){
                alert("❌ Nombre y Categoría solo deben contener letras.");
                return;
            }

            let obj = {
                nombre: nombre,
                categoria: categoria,
                stock: parseInt(stock),
                fecha: fecha
            };

            if(editIndex !== null){
                data[editIndex] = obj;
            } else {
                data.push(obj);
            }

            persist();
            closeModal();
            render();
        }

        function edit(i){
            let d = data[i];
            document.getElementById("nombre").value = d.nombre;
            document.getElementById("categoria").value = d.categoria;
            document.getElementById("stock").value = d.stock;
            document.getElementById("fecha").value = d.fecha;
            document.getElementById("modalTitle").innerText = "Editar Producto";
            editIndex = i;
            openModal();
        }

        function del(i){
            if(!permisosModulo.bitEliminar) return alert("❌ No tienes permiso.");
            if(confirm("¿Seguro que deseas eliminar este producto?")){
                data.splice(i, 1);
                persist();
                render();
            }
        }

        // --- 🛡️ INICIO SINCRONIZADO ---
        document.addEventListener("DOMContentLoaded", async () => {
            await cargarPermisos(); // Primero los permisos
            render();               // Luego dibujamos la tabla
        });
    </script>
</body>
</html>