<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>CRUD Empleados - Principal 2.2</title>
    <link rel="stylesheet" href="/css/Principal_1.1.css">
    <link rel="stylesheet" href="/css/breadcrums.css"> 

    <style>
        .pagination { margin-top: 15px; display: flex; gap: 10px; align-items: center; justify-content: center; }
        .pagination button { padding: 5px 12px; cursor: pointer; border: 1px solid #ccc; background: #fff; border-radius: 4px; }
        .pagination button:disabled { opacity: 0.5; cursor: not-allowed; }

        #btnNuevo { display: none; }

        .no-access {
            text-align: center;
            margin-top: 80px;
            color: #334155;
        }
    </style>
</head>

<body>

<%- include('partials/breadcrumb') %>

<div class="top-bar">
    <input type="text" id="search" placeholder="Buscar empleado...">
    
    <select id="rows">
        <option value="5">5</option>
        <option value="10" selected>10</option>
        <option value="15">15</option>
    </select>

    <button id="btnNuevo" class="btn-add" onclick="openModal()">+</button>
</div>

<table>
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Apellidos</th>
            <th>Teléfono</th>
            <th>Correo</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody id="tableBody"></tbody>
</table>

<div class="pagination">
    <button id="btnFirst" onclick="firstPage()">⏮</button>
    <button id="btnPrev" onclick="prevPage()">◀</button>
    <span id="pageInfo"></span>
    <button id="btnNext" onclick="nextPage()">▶</button>
    <button id="btnLast" onclick="lastPage()">⏭</button>
</div>

<div class="modal" id="modal" style="display: none;">
    <div class="modal-content">
        <h3 id="modalTitle">Registrar Empleado</h3>
        
        <label>Nombre</label>
        <input id="nombreProveedor" maxlength="50" oninput="this.value = this.value.replace(/[0-9]/g, '')">
        
        <label>Apellidos</label>
        <input id="ApellidosProveedor" maxlength="50" oninput="this.value = this.value.replace(/[0-9]/g, '')">
        
        <label>Correo</label>
        <input id="Correo" type="email">
        
        <label>Teléfono</label>
        <input id="Telefono" maxlength="15" oninput="this.value = this.value.replace(/[^0-9]/g, '')">
        
        <div class="acciones-modal">
            <button class="btn-save" onclick="save()">Guardar</button>
            <button class="btn-cancel" onclick="closeModal()">Cancelar</button>
        </div>
    </div>
</div>

<script src="/js/breadcrums.js"></script> 

<script>
// =========================
// DATOS
// =========================
let data = JSON.parse(localStorage.getItem("empleados_sucursal")) || [];
let page = 1;
let rows = 10;
let editIndex = null;

// =========================
// PERMISOS (BASE SEGURA)
// =========================
let permisosModulo = {
    bitAgregar: 0,
    bitEditar: 0,
    bitConsulta: 1, // 👈 SIEMPRE permitir ver
    bitEliminar: 0,
    bitDetalle: 0,
    bitAdministrador: 0 
};

// =========================
// CARGAR PERMISOS
// =========================
async function cargarPermisos() {
    try {
        const res = await fetch('/api/permisosPerfil/mis-permisos?modulo=Principal_2.2');

        if (res.ok) {
            const result = await res.json();
            if (result) permisosModulo = result;
            console.log("Permisos cargados:", permisosModulo);
        } else {
            console.warn("Sin permisos en BD → modo lectura");
        }

    } catch (error) {
        console.error("Error permisos:", error);
    }

    // Actualizar UI según permisos
    actualizarUIporPermisos();
}

// 🆕 Función separada para actualizar la UI
function actualizarUIporPermisos() {
    const puedeAgregar = permisosModulo.bitAdministrador || permisosModulo.bitAgregar;
    const btn = document.getElementById('btnNuevo');
    if(btn) btn.style.display = puedeAgregar ? 'block' : 'none';
    
    // Re-renderizar la tabla para que los botones de editar/eliminar se actualicen
    render();
}

// 🆕 Escuchar cambios globales de permisos
function escucharCambiosPermisos() {
    window.addEventListener('permisosActualizados', async (event) => {
        console.log('🔄 Permisos actualizados, recargando...', event.detail);
        
        // Recargar permisos desde el servidor
        await cargarPermisos();
        
        // Mostrar notificación opcional
        mostrarNotificacion('Los permisos han sido actualizados', 'info');
    });
}

// 🆕 Notificación visual (opcional pero recomendada)
function mostrarNotificacion(mensaje, tipo = 'info') {
    // Crear elemento de notificación flotante
    const notif = document.createElement('div');
    notif.textContent = mensaje;
    notif.style.cssText = `
        position: fixed;
        bottom: 20px;
        right: 20px;
        background: ${tipo === 'error' ? '#dc2626' : '#10b981'};
        color: white;
        padding: 12px 20px;
        border-radius: 8px;
        z-index: 10000;
        animation: slideIn 0.3s ease;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    `;
    
    document.body.appendChild(notif);
    
    setTimeout(() => {
        notif.style.animation = 'slideOut 0.3s ease';
        setTimeout(() => notif.remove(), 300);
    }, 3000);
}

// Agregar estilos para las animaciones (poner en el <style>)
const style = document.createElement('style');
style.textContent = `
    @keyframes slideIn {
        from { transform: translateX(100%); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
    }
    @keyframes slideOut {
        from { transform: translateX(0); opacity: 1; }
        to { transform: translateX(100%); opacity: 0; }
    }
`;
document.head.appendChild(style);

// Modificar el DOMContentLoaded
document.addEventListener("DOMContentLoaded", async () => {
    await cargarPermisos();
    escucharCambiosPermisos(); // 🆕 Activar listener
    render();
});
</script>

</body>
</html>