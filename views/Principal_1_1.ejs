<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>CRUD Productos</title>
    <link rel="stylesheet" href="/css/Principal_1.1.css">
    <link rel="stylesheet" href="/css/breadcrums.css"> 
</head>

<body>
    <%- include('partials/breadcrumb') %>
 
    <div class="top-bar">
        <input type="text" id="search" placeholder="Buscar producto o categoría...">
        
        <select id="rows">
            <option value="5">5</option>
            <option value="10" selected>10</option>
            <option value="15">15</option>
        </select>

        <button class="btn-add" onclick="openModal()">+</button>
    </div>

    <table>
        <thead>
            <tr>
                <th>Nombre Producto</th>
                <th>Categoría</th>
                <th>Stock</th>
                <th>Fecha Caducidad</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody id="tableBody"></tbody>
    </table>

    <div class="pagination">
        <button onclick="firstPage()">⏮</button>
        <button onclick="prevPage()">◀</button>
        <span id="pageInfo"></span>
        <button onclick="nextPage()">▶</button>
        <button onclick="lastPage()">⏭</button>
    </div>

    <div class="modal" id="modal">
        <div class="modal-content">
            <h3 id="modalTitle">Registrar Producto</h3>
            
            <label>Nombre del Producto</label>
            <input id="nombre" placeholder="Solo letras" 
                   maxlength="50" 
                   oninput="this.value = this.value.replace(/[0-9]/g, '')">
            
            <label>Categoría</label>
            <input id="categoria" placeholder="Solo letras"
             maxlength="50" 
                   oninput="this.value = this.value.replace(/[0-9]/g, '')">
            
            <label>Stock disponible</label>
            <input id="stock" type="number" placeholder="0" min="0"
                   oninput="if(this.value < 0) this.value = 0">
            
            <label>Fecha de Vencimiento</label>
            <input id="fecha" type="date">
            
            <div class="acciones-modal">
                <button class="btn-guardar" onclick="save()">Guardar</button>
                <button class="btn-cancelar" onclick="closeModal()">Cancelar</button>
            </div>
        </div>
    </div>

    <script src="/js/breadcrums.js"></script> 

    <script>
        let data = JSON.parse(localStorage.getItem("productos")) || [];
        let page = 1;
        let rows = 10;
        let editIndex = null;

        function persist(){
            localStorage.setItem("productos", JSON.stringify(data));
        }

        function totalPages(filteredLength){
            return Math.ceil(filteredLength / rows) || 1;
        }

        function getFilteredData(){
            let search = document.getElementById("search").value.toLowerCase();
            return data.filter(d =>
                d.nombre.toLowerCase().includes(search) ||
                d.categoria.toLowerCase().includes(search) ||
                d.stock.toString().includes(search) ||
                d.fecha.includes(search)
            );
        }

        function render(){
            let tbody = document.getElementById("tableBody");
            tbody.innerHTML = "";

            let filtered = getFilteredData();
            let start = (page-1)*rows;
            let paginated = filtered.slice(start, start+rows);

            paginated.forEach((d, i) => {
                let realIndex = data.indexOf(d); // Indice real en el array original
                let row = "<tr>" +
                    "<td>" + d.nombre + "</td>" +
                    "<td>" + d.categoria + "</td>" +
                    "<td>" + d.stock + "</td>" +
                    "<td>" + d.fecha + "</td>" +
                    "<td>" +
                        "<button class='btn-edit' onclick='edit(" + realIndex + ")'>✏️</button>" +
                        "<button class='btn-delete' onclick='del(" + realIndex + ")'>🗑</button>" +
                    "</td>" +
                "</tr>";
                tbody.innerHTML += row;
            });

            let total = totalPages(filtered.length);
            if(page > total && total > 0) page = total;
            document.getElementById("pageInfo").innerText = "Página " + page + " de " + total;
        }

        // PAGINACIÓN
        function nextPage(){ if(page < totalPages(getFilteredData().length)){ page++; render(); } }
        function prevPage(){ if(page > 1){ page--; render(); } }
        function firstPage(){ page = 1; render(); }
        function lastPage(){ page = totalPages(getFilteredData().length); render(); }

        document.getElementById("rows").addEventListener("change", e => {
            rows = parseInt(e.target.value);
            page = 1;
            render();
        });

        document.getElementById("search").addEventListener("input", () => {
            page = 1;
            render();
        });

        // MODAL LOGIC
        function openModal(){ 
            document.getElementById("modal").style.display = "flex"; 
        }

        function closeModal(){
            document.getElementById("modal").style.display = "none";
            clear();
        }

        function clear(){
            document.getElementById("nombre").value = "";
            document.getElementById("categoria").value = "";
            document.getElementById("stock").value = "";
            document.getElementById("fecha").value = "";
            document.getElementById("modalTitle").innerText = "Registrar Producto";
            editIndex = null;
        }

        // 🛡️ GUARDAR CON VALIDACIONES
        function save(){
            const nombre = document.getElementById("nombre").value.trim();
            const categoria = document.getElementById("categoria").value.trim();
            const stock = document.getElementById("stock").value;
            const fecha = document.getElementById("fecha").value;

            // Validación: Campos vacíos
            if(!nombre || !categoria || !stock || !fecha){
                alert("❌ Todos los campos son obligatorios.");
                return;
            }

            // Validación: Solo letras (doble verificación)
            const regexLetras = /^[A-Za-zÁ-ú\sñÑ]+$/;
            if(!regexLetras.test(nombre) || !regexLetras.test(categoria)){
                alert("❌ Nombre y Categoría solo deben contener letras.");
                return;
            }

            let obj = {
                nombre: nombre,
                categoria: categoria,
                stock: parseInt(stock),
                fecha: fecha
            };

            if(editIndex !== null){
                data[editIndex] = obj;
            } else {
                data.push(obj);
            }

            persist();
            closeModal();
            render();
        }

        function edit(i){
            let d = data[i];
            document.getElementById("nombre").value = d.nombre;
            document.getElementById("categoria").value = d.categoria;
            document.getElementById("stock").value = d.stock;
            document.getElementById("fecha").value = d.fecha;
            document.getElementById("modalTitle").innerText = "Editar Producto";
            editIndex = i;
            openModal();
        }

        function del(i){
            if(confirm("¿Seguro que deseas eliminar este producto?")){
                data.splice(i, 1);
                persist();
                render();
            }
        }

        document.addEventListener("DOMContentLoaded", render);
    </script>
</body>
</html>