<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>CRUD Empleados - Principal 1.1</title>
    <link rel="stylesheet" href="/css/Principal_1.1.css">
    <link rel="stylesheet" href="/css/breadcrums.css"> 
</head>

<body>

<%- include('partials/breadcrumb') %>

<div class="top-bar">
    <input type="text" id="search" placeholder="Buscar empleado...">
    
    <select id="rows">
        <option value="5">5</option>
        <option value="10" selected>10</option>
        <option value="15">15</option>
    </select>

    <button id="btnNuevo" class="btn-add" onclick="openModal()">+ Nuevo</button>
</div>

<table>
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Apellidos</th>
            <th>Teléfono</th>
            <th>Correo</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody id="tableBody"></tbody>
</table>

<div class="pagination">
    <button id="btnFirst" onclick="firstPage()">⏮</button>
    <button id="btnPrev" onclick="prevPage()">◀</button>
    <span id="pageInfo"></span>
    <button id="btnNext" onclick="nextPage()">▶</button>
    <button id="btnLast" onclick="lastPage()">⏭</button>
</div>

<div id="modal" class="modal" style="display: none;">
    <div class="modal-content">
        <h3 id="modalTitle">Registrar Empleado</h3>
        
        <label>Nombre *</label>
        <input id="nombreProveedor" maxlength="50" placeholder="Ingrese el nombre">
        
        <label>Apellidos *</label>
        <input id="ApellidosProveedor" maxlength="50" placeholder="Ingrese los apellidos">
        
        <label>Correo</label>
        <input id="Correo" type="email" placeholder="ejemplo@correo.com">
        
        <label>Teléfono</label>
        <input id="Telefono" maxlength="15" placeholder="Número de teléfono">
        
        <div class="acciones-modal">
            <button class="btn-save" onclick="save()">Guardar</button>
            <button class="btn-cancel" onclick="closeModal()">Cancelar</button>
        </div>
    </div>
</div>

<script src="/js/breadcrums.js"></script> 

<script>
// =========================
// DATOS - Inicializar con datos de ejemplo si está vacío
// =========================
let data = [];
let page = 1;
let rows = 10;
let editIndex = null;

// Inicializar datos de ejemplo si no hay datos
function inicializarDatosEjemplo() {
    const stored = localStorage.getItem("empleados_sucursal");
    
    if (stored && JSON.parse(stored).length > 0) {
        data = JSON.parse(stored);
        console.log("📦 Datos cargados desde localStorage:", data.length, "registros");
    } else {
        // Datos de ejemplo para mostrar que funciona
        data = [
            {
                nombreProveedor: "Juan",
                apellidosProveedor: "Pérez García",
                correo: "juan.perez@example.com",
                telefono: "5551234567"
            },
            {
                nombreProveedor: "María",
                apellidosProveedor: "López Martínez",
                correo: "maria.lopez@example.com",
                telefono: "5559876543"
            },
            {
                nombreProveedor: "Carlos",
                apellidosProveedor: "Rodríguez Sánchez",
                correo: "carlos.rodriguez@example.com",
                telefono: "5554567890"
            }
        ];
        persist();
        console.log("📝 Datos de ejemplo creados:", data.length, "registros");
    }
}

// =========================
// PERMISOS - CORREGIDO: Principal_1.1
// =========================
let permisosModulo = {
    bitAgregar: 0,
    bitEditar: 0,
    bitConsulta: 1,
    bitEliminar: 0,
    bitDetalle: 0,
    bitAdministrador: 0 
};

// =========================
// CARGAR PERMISOS - CON TIMESTAMP PARA EVITAR CACHE
// =========================
async function cargarPermisos() {
    try {
        // ✅ CORREGIDO: Cambiar a Principal_1.1 y agregar timestamp
        const res = await fetch('/api/permisosPerfil/mis-permisos?modulo=Principal_1.1&t=' + Date.now());

        if (res.ok) {
            const result = await res.json();
            if (result) {
                permisosModulo = result;
                console.log("✅ Permisos cargados:", permisosModulo);
                console.log("¿Puede agregar?", permisosModulo.bitAdministrador || permisosModulo.bitAgregar);
            }
        } else {
            console.warn("⚠️ Sin permisos en BD → modo lectura");
            // Mantener permisos por defecto
        }

    } catch (error) {
        console.error("❌ Error permisos:", error);
    }

    // Actualizar UI según permisos
    actualizarUIporPermisos();
}

// Función para actualizar la UI
function actualizarUIporPermisos() {
    const puedeAgregar = permisosModulo.bitAdministrador || permisosModulo.bitAgregar;
    const btn = document.getElementById('btnNuevo');
    if(btn) {
        btn.style.display = puedeAgregar ? 'block' : 'none';
        console.log("Botón Nuevo visible?", puedeAgregar);
    }
    
    // Re-renderizar la tabla
    render();
}

// Validar permiso específico
async function validarPermiso(tipoAccion) {
    // Recargar permisos para asegurar datos actualizados
    await cargarPermisos();
    
    let tienePermiso = false;
    switch(tipoAccion) {
        case 'agregar':
            tienePermiso = permisosModulo.bitAdministrador || permisosModulo.bitAgregar;
            break;
        case 'editar':
            tienePermiso = permisosModulo.bitAdministrador || permisosModulo.bitEditar;
            break;
        case 'eliminar':
            tienePermiso = permisosModulo.bitAdministrador || permisosModulo.bitEliminar;
            break;
        default:
            tienePermiso = true;
    }
    
    if (!tienePermiso) {
        alert(`❌ No tienes permiso para ${tipoAccion} registros`);
        return false;
    }
    return true;
}

// =========================
// STORAGE
// =========================
function persist(){
    localStorage.setItem("empleados_sucursal", JSON.stringify(data));
    console.log("💾 Datos guardados:", data.length, "registros");
}

// =========================
// FILTRO
// =========================
function getFilteredData(){
    const search = (document.getElementById("search")?.value || "").toLowerCase();
    
    if (!search) return data;
    
    return data.filter(d =>
        (d.nombreProveedor || "").toLowerCase().includes(search) ||
        (d.apellidosProveedor || "").toLowerCase().includes(search) ||
        (d.correo || "").toLowerCase().includes(search) ||
        (d.telefono || "").toString().includes(search)
    );
}

// =========================
// RENDER - Versión mejorada
// =========================
function render(){
    const tbody = document.getElementById("tableBody");
    if (!tbody) return;
    
    tbody.innerHTML = "";

    const filtered = getFilteredData();
    
    if (filtered.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" style="text-align: center;">No hay registros disponibles</td></tr>';
        document.getElementById("pageInfo").innerText = `Página 1 de 1`;
        return;
    }
    
    const total = Math.ceil(filtered.length / rows) || 1;
    if(page > total) page = total;
    if(page < 1) page = 1;

    const start = (page - 1) * rows;
    const paginated = filtered.slice(start, start + rows);

    paginated.forEach((item, idx) => {
        // Encontrar el índice real en data
        const realIndex = data.findIndex(d => 
            d.nombreProveedor === item.nombreProveedor && 
            d.apellidosProveedor === item.apellidosProveedor &&
            d.correo === item.correo
        );
        
        const puedeEditar = permisosModulo.bitAdministrador || permisosModulo.bitEditar;
        const puedeEliminar = permisosModulo.bitAdministrador || permisosModulo.bitEliminar;

        let acciones = "";
        
        if (puedeEditar) {
            acciones += `<button onclick="edit(${realIndex})" style="margin-right: 5px; padding: 5px 10px;">✏️ Editar</button>`;
        }
        
        if (puedeEliminar) {
            acciones += `<button onclick="del(${realIndex})" style="padding: 5px 10px;">🗑 Eliminar</button>`;
        }
        
        if (!acciones) {
            acciones = `<span style="color:gray;">Solo lectura</span>`;
        }

        const row = tbody.insertRow();
        row.insertCell(0).textContent = item.nombreProveedor || '';
        row.insertCell(1).textContent = item.apellidosProveedor || '';
        row.insertCell(2).textContent = item.telefono || '';
        row.insertCell(3).textContent = item.correo || '';
        row.insertCell(4).innerHTML = acciones;
    });

    document.getElementById("pageInfo").innerText = `Página ${page} de ${total}`;
    
    // Actualizar estado de botones de paginación
    const btnFirst = document.getElementById('btnFirst');
    const btnPrev = document.getElementById('btnPrev');
    const btnNext = document.getElementById('btnNext');
    const btnLast = document.getElementById('btnLast');
    
    if (btnFirst) btnFirst.disabled = page <= 1;
    if (btnPrev) btnPrev.disabled = page <= 1;
    if (btnNext) btnNext.disabled = page >= total;
    if (btnLast) btnLast.disabled = page >= total;
}

// =========================
// PAGINACIÓN
// =========================
function firstPage(){ page = 1; render(); }
function prevPage(){ if(page > 1){ page--; render(); } }
function nextPage(){ 
    const total = Math.ceil(getFilteredData().length / rows) || 1;
    if(page < total){ page++; render(); } 
}
function lastPage(){ 
    const total = Math.ceil(getFilteredData().length / rows) || 1;
    page = total; 
    render(); 
}

// =========================
// MODAL
// =========================
async function openModal(){
    const tienePermiso = await validarPermiso('agregar');
    if (!tienePermiso) return;
    
    document.getElementById("modal").style.display = "flex";
    document.getElementById("modalTitle").textContent = "Registrar Empleado";
    editIndex = null;
    
    // Limpiar campos
    document.getElementById("nombreProveedor").value = "";
    document.getElementById("ApellidosProveedor").value = "";
    document.getElementById("Correo").value = "";
    document.getElementById("Telefono").value = "";
}

function closeModal(){
    document.getElementById("modal").style.display = "none";
    document.getElementById("nombreProveedor").value = "";
    document.getElementById("ApellidosProveedor").value = "";
    document.getElementById("Correo").value = "";
    document.getElementById("Telefono").value = "";
    editIndex = null;
}

// =========================
// CRUD
// =========================
async function save(){
    const isEdit = editIndex !== null;
    const tipoAccion = isEdit ? 'editar' : 'agregar';
    
    // Validar permisos antes de guardar
    const tienePermiso = await validarPermiso(tipoAccion);
    if (!tienePermiso) return;
    
    const nombre = document.getElementById("nombreProveedor").value.trim();
    const apellidos = document.getElementById("ApellidosProveedor").value.trim();

    if(!nombre || !apellidos) {
        alert("❌ Nombre y apellidos son campos obligatorios");
        return;
    }
    
    // Validar correo si se ingresó
    const correo = document.getElementById("Correo").value.trim();
    if (correo && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(correo)) {
        alert("❌ Ingrese un correo electrónico válido");
        return;
    }

    const obj = {
        nombreProveedor: nombre,
        apellidosProveedor: apellidos,
        correo: correo,
        telefono: document.getElementById("Telefono").value.trim()
    };

    if(editIndex !== null) {
        data[editIndex] = obj;
        console.log("✏️ Registro editado en índice:", editIndex);
    } else {
        data.push(obj);
        console.log("➕ Nuevo registro agregado");
    }

    persist();
    closeModal();
    render();
}

async function edit(i){
    const tienePermiso = await validarPermiso('editar');
    if (!tienePermiso) return;
    
    if (i < 0 || i >= data.length) {
        console.error("Índice inválido:", i);
        return;
    }
    
    editIndex = i;
    const d = data[i];

    document.getElementById("nombreProveedor").value = d.nombreProveedor || '';
    document.getElementById("ApellidosProveedor").value = d.apellidosProveedor || '';
    document.getElementById("Correo").value = d.correo || '';
    document.getElementById("Telefono").value = d.telefono || '';
    
    document.getElementById("modal").style.display = "flex";
    document.getElementById("modalTitle").textContent = "Editar Empleado";
}

async function del(i){
    const tienePermiso = await validarPermiso('eliminar');
    if (!tienePermiso) return;
    
    if(confirm("¿Está seguro de eliminar este empleado?")){
        data.splice(i, 1);
        persist();
        
        // Ajustar página si es necesario
        const filtered = getFilteredData();
        const totalPages = Math.ceil(filtered.length / rows) || 1;
        if (page > totalPages) page = totalPages;
        if (page < 1) page = 1;
        
        render();
        console.log("🗑 Registro eliminado");
    }
}

// =========================
// EVENTOS
// =========================
function setupEventListeners() {
    const searchInput = document.getElementById("search");
    if (searchInput) {
        searchInput.addEventListener("input", () => { 
            page = 1; 
            render(); 
        });
    }
    
    const rowsSelect = document.getElementById("rows");
    if (rowsSelect) {
        rowsSelect.addEventListener("change", (e) => { 
            rows = parseInt(e.target.value); 
            page = 1; 
            render(); 
        });
    }
}

// =========================
// INIT
// =========================
document.addEventListener("DOMContentLoaded", async () => {
    console.log("🚀 Inicializando Principal_1.1...");
    
    // Inicializar datos
    inicializarDatosEjemplo();
    
    // Configurar event listeners
    setupEventListeners();
    
    // Cargar permisos (esto también hará render)
    await cargarPermisos();
    
    console.log("✅ Inicialización completada");
    console.log("Permisos finales:", permisosModulo);
});
</script>

</body>
</html>