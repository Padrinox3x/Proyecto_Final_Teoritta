<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>CRUD Productos</title>
    <link rel="stylesheet" href="/css/Principal_1.1.css">
    <link rel="stylesheet" href="/css/breadcrums.css"> 
    <style>
        /* Estilo rápido para los botones de paginación si no los tienes en tu CSS */
        .pagination { margin-top: 15px; display: flex; gap: 10px; align-items: center; justify-content: center; }
        .pagination button { padding: 5px 10px; cursor: pointer; border: 1px solid #ccc; background: #fff; }
        .pagination button:disabled { opacity: 0.5; cursor: not-allowed; }
    </style>
</head>

<body>
    <%- include('partials/breadcrumb') %>
 
   <div class="top-bar">
        <input type="text" id="search" placeholder="Buscar producto o categoría...">
        
        <select id="rows">
            <option value="5">5</option>
            <option value="10" selected>10</option>
            <option value="15">15</option>
        </select>

        <button id="btnNuevo" class="btn-add" onclick="openModal()">+</button>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Categoría</th>
                <th>Stock</th>
                <th>Fecha</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody id="tableBody"></tbody>
    </table>

    <div class="pagination">
        <button id="btnPrev" onclick="changePage(-1)">Anterior</button>
        <div id="pageInfo"></div>
        <button id="btnNext" onclick="changePage(1)">Siguiente</button>
    </div>

    <script src="/js/breadcrums.js"></script> 

    <script>
    let data = JSON.parse(localStorage.getItem("productos")) || [];
    let page = 1;
    let rows = 10;
    let editIndex = null;

    // --- 🛡️ ESTADO GLOBAL DE PERMISOS ---
    let permisosModulo = {
        bitAgregar: 0, bitEditar: 0, bitConsulta: 0, bitEliminar: 0, bitDetalle: 0,
        bitAdministrador: 0 
    };

    async function cargarPermisos() {
        try {
            // IMPORTANTE: El nombre del módulo debe ser igual al de tu base de datos
            const res = await fetch('/api/permisosPerfil/mis-permisos?modulo=Principal_1.1');
            const result = await res.json();
            
            permisosModulo = result;
            
            // Actualización inmediata de botones globales
            const puedeAgregar = permisosModulo.bitAdministrador || permisosModulo.bitAgregar;
            const btnNuevo = document.getElementById('btnNuevo');
            if (btnNuevo) btnNuevo.style.display = puedeAgregar ? 'block' : 'none';

        } catch (error) {
            console.error("Error cargando permisos del módulo:", error);
        }
    }

    function render() {
        let tbody = document.getElementById("tableBody");
        if (!tbody) return;
        tbody.innerHTML = "";

        let filtered = getFilteredData();
        let total = Math.ceil(filtered.length / rows) || 1;
        
        if(page > total) page = total;

        let start = (page - 1) * rows;
        let paginated = filtered.slice(start, start + rows);

        paginated.forEach((d) => {
            let realIndex = data.indexOf(d);
            
            // Verificación de permisos por fila
            const puedeEditar = permisosModulo.bitAdministrador || permisosModulo.bitEditar;
            const puedeEliminar = permisosModulo.bitAdministrador || permisosModulo.bitEliminar;

            let btnEdit = puedeEditar 
                ? `<button class='btn-edit' onclick='edit(${realIndex})'>✏️</button>` 
                : "";
            
            let btnDel = puedeEliminar 
                ? `<button class='btn-delete' onclick='del(${realIndex})'>🗑</button>` 
                : "";

            if (!puedeEditar && !puedeEliminar) {
                btnEdit = "<span style='color:gray;font-size:11px;'>Solo lectura</span>";
            }

            tbody.innerHTML += `<tr>
                <td>${d.nombre}</td>
                <td>${d.categoria}</td>
                <td>${d.stock}</td>
                <td>${d.fecha}</td>
                <td>${btnEdit} ${btnDel}</td>
            </tr>`;
        });

        document.getElementById("pageInfo").innerText = `Página ${page} de ${total}`;
        document.getElementById("btnPrev").disabled = (page === 1);
        document.getElementById("btnNext").disabled = (page === total);
    }

    // --- 🚀 INICIALIZACIÓN CRÍTICA ---
    document.addEventListener("DOMContentLoaded", async () => {
        // PASO 1: Esperar a que los permisos lleguen del servidor
        await cargarPermisos();
        
        // PASO 2: Solo ahora que 'permisosModulo' tiene datos, dibujamos la tabla
        render();
    });

    // ... Resto de tus funciones (save, del, edit, getFilteredData) se mantienen igual ...
</script>
</body>
</html>