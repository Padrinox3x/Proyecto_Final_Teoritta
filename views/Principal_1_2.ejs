<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>CRUD Proveedores</title>
<link rel="stylesheet" href="/css/Principal_1.1.css">
<link rel="stylesheet" href="/css/breadcrums.css"> 
</head>

<body>

<%- include('partials/breadcrumb') %>

<div class="top-bar">
    <input type="text" id="search" placeholder="Buscar proveedor...">
    
    <select id="rows">
        <option value="5">5</option>
        <option value="10" selected>10</option>
        <option value="15">15</option>
    </select>

    <button class="btn-add" onclick="openModal()">+</button>
</div>

<table>
<thead>
<tr>
    <th>Nombre</th>
    <th>Apellidos</th>
    <th>Teléfono</th>
    <th>Correo</th>
    <th>Acciones</th>
</tr>
</thead>
<tbody id="tableBody"></tbody>
</table>

<div class="pagination">
    <button onclick="firstPage()">⏮</button>
    <button onclick="prevPage()">◀</button>
    <span id="pageInfo"></span>
    <button onclick="nextPage()">▶</button>
    <button onclick="lastPage()">⏭</button>
</div>

<div class="modal" id="modal">
    <div class="modal-content">
        <h3 id="modalTitle">Registrar Proveedor</h3>
        
        <label>Nombre</label>
        <input id="nombreProveedor" placeholder="Ej. Juan" 
         maxlength="50" 
               oninput="this.value = this.value.replace(/[0-9]/g, '')">
        
        <label>Apellidos</label>
        <input id="ApellidosProveedor" placeholder="Ej. Pérez" 
         maxlength="50" 
               oninput="this.value = this.value.replace(/[0-9]/g, '')">
        
        <label>Correo Electrónico</label>
        <input id="Correo" type="email" placeholder="correo@ejemplo.com">
        
        <label>Teléfono</label>
        <input id="Telefono" placeholder="Solo números" maxlength="15"
               oninput="this.value = this.value.replace(/[^0-9]/g, '')">
        
        <div class="acciones-modal">
            <button class="btn-save" onclick="save()">Guardar</button>
            <button class="btn-cancel" onclick="closeModal()">Cancelar</button>
        </div>
    </div>
</div>

<script src="/js/breadcrums.js"></script> 

<script>
let data = JSON.parse(localStorage.getItem("proveedores")) || [];
let page = 1;
let rows = 10;
let editIndex = null;

function persist(){
    localStorage.setItem("proveedores", JSON.stringify(data));
}

function totalPages(filteredLength){
    return Math.ceil(filteredLength / rows) || 1;
}

function getFilteredData(){
    let search = document.getElementById("search").value.toLowerCase();
    return data.filter(d =>
        d.nombreProveedor.toLowerCase().includes(search) ||
        d.apellidosProveedor.toLowerCase().includes(search) ||
        d.correo.toLowerCase().includes(search) ||
        d.telefono.toString().includes(search)
    );
}

function render(){
    let tbody = document.getElementById("tableBody");
    tbody.innerHTML = "";
    let filtered = getFilteredData();
    let start = (page-1)*rows;
    let paginated = filtered.slice(start, start+rows);

    paginated.forEach((d, i) => {
        let realIndex = data.indexOf(d); 
        tbody.innerHTML += `
        <tr>
            <td>${d.nombreProveedor}</td>
            <td>${d.apellidosProveedor}</td>
            <td>${d.telefono}</td>
            <td>${d.correo}</td>
            <td>
                <button class="btn-edit" onclick="edit(${realIndex})">✏️</button>
                <button class="btn-delete" onclick="del(${realIndex})">🗑</button>
            </td>
        </tr>`;
    });

    let total = totalPages(filtered.length);
    if(page > total && total > 0) page = total;
    document.getElementById("pageInfo").innerText = `Página ${page} de ${total}`;
}

/* FUNCIONES DE NAVEGACIÓN */
function nextPage(){ if(page < totalPages(getFilteredData().length)){ page++; render(); } }
function prevPage(){ if(page > 1){ page--; render(); } }
function firstPage(){ page = 1; render(); }
function lastPage(){ page = totalPages(getFilteredData().length); render(); }

document.getElementById("rows").addEventListener("change", e => {
    rows = parseInt(e.target.value);
    page = 1;
    render();
});

document.getElementById("search").addEventListener("input", () => {
    page = 1;
    render();
});

/* LÓGICA MODAL */
function openModal(){ document.getElementById("modal").style.display="flex"; }

function closeModal(){
    document.getElementById("modal").style.display="none";
    clear();
}

function clear(){
    document.getElementById("nombreProveedor").value="";
    document.getElementById("ApellidosProveedor").value="";
    document.getElementById("Correo").value="";
    document.getElementById("Telefono").value="";
    document.getElementById("modalTitle").innerText = "Registrar Proveedor";
    editIndex = null;
}

/* 🛡️ GUARDAR CON VALIDACIÓN CRÍTICA */
function save(){
    const nombre = document.getElementById("nombreProveedor").value.trim();
    const apellidos = document.getElementById("ApellidosProveedor").value.trim();
    const correo = document.getElementById("Correo").value.trim();
    const telefono = document.getElementById("Telefono").value.trim();

    // 1. Campos obligatorios
    if(!nombre || !apellidos || !correo || !telefono){
        alert("❌ Todos los campos son obligatorios.");
        return;
    }

    // 2. Formato de Correo
    const regexEmail = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if(!regexEmail.test(correo)){
        alert("❌ Por favor, ingrese un correo electrónico válido.");
        return;
    }

    // 3. Longitud mínima
    if(nombre.length < 2 || apellidos.length < 2){
        alert("❌ Nombre y apellidos deben tener al menos 2 caracteres.");
        return;
    }

    let obj = {
        nombreProveedor: nombre,
        apellidosProveedor: apellidos,
        correo: correo,
        telefono: telefono
    };

    if(editIndex !== null){
        data[editIndex] = obj;
    }else{
        data.push(obj);
    }

    persist();
    closeModal();
    render();
}

function edit(i){
    let d = data[i];
    document.getElementById("nombreProveedor").value = d.nombreProveedor;
    document.getElementById("ApellidosProveedor").value = d.apellidosProveedor;
    document.getElementById("Correo").value = d.correo;
    document.getElementById("Telefono").value = d.telefono;
    document.getElementById("modalTitle").innerText = "Editar Proveedor";
    editIndex = i;
    openModal();
}

function del(i){
    if(confirm("¿Seguro que deseas eliminar este proveedor?")){
        data.splice(i,1);
        persist();
        render();
    }
}

document.addEventListener("DOMContentLoaded", render);
</script>

</body>
</html>