<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>CRUD Proveedores</title>
<link rel="stylesheet" href="/css/Principal_1.1.css">
<link rel="stylesheet" href="/css/breadcrums.css"> 
</head>

<body>

<%- include('partials/breadcrumb') %>

<div class="top-bar">
        <input type="text" id="search" placeholder="Buscar proveedor...">
        
        <select id="rows">
            <option value="5">5</option>
            <option value="10" selected>10</option>
            <option value="15">15</option>
        </select>

        <button id="btnNuevo" class="btn-add" onclick="openModal()">+</button>
    </div>

<table>
<thead>
<tr>
    <th>Nombre</th>
    <th>Apellidos</th>
    <th>Teléfono</th>
    <th>Correo</th>
    <th>Acciones</th>
</tr>
</thead>
<tbody id="tableBody"></tbody>
</table>

<div class="pagination">
    <button onclick="firstPage()">⏮</button>
    <button onclick="prevPage()">◀</button>
    <span id="pageInfo"></span>
    <button onclick="nextPage()">▶</button>
    <button onclick="lastPage()">⏭</button>
</div>

<div class="modal" id="modal">
    <div class="modal-content">
        <h3 id="modalTitle">Registrar Proveedor</h3>
        
        <label>Nombre</label>
        <input id="nombreProveedor" placeholder="Ej. Juan" 
         maxlength="50" 
               oninput="this.value = this.value.replace(/[0-9]/g, '')">
        
        <label>Apellidos</label>
        <input id="ApellidosProveedor" placeholder="Ej. Pérez" 
         maxlength="50" 
               oninput="this.value = this.value.replace(/[0-9]/g, '')">
        
        <label>Correo Electrónico</label>
        <input id="Correo" type="email" placeholder="correo@ejemplo.com">
        
        <label>Teléfono</label>
        <input id="Telefono" placeholder="Solo números" maxlength="15"
               oninput="this.value = this.value.replace(/[^0-9]/g, '')">
        
        <div class="acciones-modal">
            <button class="btn-save" onclick="save()">Guardar</button>
            <button class="btn-cancel" onclick="closeModal()">Cancelar</button>
        </div>
    </div>
</div>

<script src="/js/breadcrums.js"></script> 

<script>
let data = JSON.parse(localStorage.getItem("proveedores")) || [];
let page = 1;
let rows = 10;
let editIndex = null;

// --- 🛡️ ESTADO GLOBAL DE PERMISOS ---
let permisosModulo = {
    bitAgregar: 0, bitEditar: 0, bitConsulta: 0, bitEliminar: 0, bitDetalle: 0
};

// --- 🛡️ CARGAR PERMISOS DESDE EL SERVIDOR (Principal_1_2) ---
async function cargarPermisos() {
    try {
        // Vinculamos este archivo con el módulo Principal_1_2 en tu DB
        const res = await fetch('/api/permisosPerfil/mis-permisos?modulo=Principal_1_2');
        permisosModulo = await res.json();
        
        // Ocultar botón "+" si no tiene permiso
        if (!permisosModulo.bitAgregar) {
            const btn = document.getElementById('btnNuevo');
            if(btn) btn.style.display = 'none';
        }
    } catch (error) {
        console.error("Error cargando permisos de Proveedores:", error);
    }
}

function persist(){
    localStorage.setItem("proveedores", JSON.stringify(data));
}

function totalPages(filteredLength){
    return Math.ceil(filteredLength / rows) || 1;
}

function getFilteredData(){
    let search = document.getElementById("search").value.toLowerCase();
    return data.filter(d =>
        d.nombreProveedor.toLowerCase().includes(search) ||
        d.apellidosProveedor.toLowerCase().includes(search) ||
        d.correo.toLowerCase().includes(search) ||
        d.telefono.toString().includes(search)
    );
}

function render(){
    let tbody = document.getElementById("tableBody");
    tbody.innerHTML = "";
    let filtered = getFilteredData();
    let start = (page-1)*rows;
    let paginated = filtered.slice(start, start+rows);

    paginated.forEach((d, i) => {
        let realIndex = data.indexOf(d); 
        
        // --- 🛡️ RENDERIZADO SEGURO DE BOTONES ---
        let botonesAccion = "";
        if (permisosModulo.bitEditar) {
            botonesAccion += `<button class="btn-edit" onclick="edit(${realIndex})">✏️</button> `;
        }
        if (permisosModulo.bitEliminar) {
            botonesAccion += `<button class="btn-delete" onclick="del(${realIndex})">🗑</button>`;
        }
        if (!permisosModulo.bitEditar && !permisosModulo.bitEliminar) {
            botonesAccion = '<span style="color:gray; font-size:11px;">Lectura</span>';
        }

        tbody.innerHTML += `
        <tr>
            <td>${d.nombreProveedor}</td>
            <td>${d.apellidosProveedor}</td>
            <td>${d.telefono}</td>
            <td>${d.correo}</td>
            <td>${botonesAccion}</td>
        </tr>`;
    });

    let total = totalPages(filtered.length);
    if(page > total && total > 0) page = total;
    document.getElementById("pageInfo").innerText = `Página ${page} de ${total}`;
}

/* ... (Funciones de navegación y modal se mantienen igual) ... */

/* 🛡️ GUARDAR PROTEGIDO */
function save(){
    // Verificación de integridad de permisos
    if(editIndex !== null && !permisosModulo.bitEditar) return alert("❌ No tienes permiso para editar.");
    if(editIndex === null && !permisosModulo.bitAgregar) return alert("❌ No tienes permiso para registrar.");

    const nombre = document.getElementById("nombreProveedor").value.trim();
    const apellidos = document.getElementById("ApellidosProveedor").value.trim();
    const correo = document.getElementById("Correo").value.trim();
    const telefono = document.getElementById("Telefono").value.trim();

    if(!nombre || !apellidos || !correo || !telefono){
        alert("❌ Todos los campos son obligatorios.");
        return;
    }

    const regexEmail = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if(!regexEmail.test(correo)){
        alert("❌ Formato de correo inválido.");
        return;
    }

    let obj = {
        nombreProveedor: nombre,
        apellidosProveedor: apellidos,
        correo: correo,
        telefono: telefono
    };

    if(editIndex !== null){
        data[editIndex] = obj;
    }else{
        data.push(obj);
    }

    persist();
    closeModal();
    render();
}

function edit(i){
    let d = data[i];
    document.getElementById("nombreProveedor").value = d.nombreProveedor;
    document.getElementById("ApellidosProveedor").value = d.apellidosProveedor;
    document.getElementById("Correo").value = d.correo;
    document.getElementById("Telefono").value = d.telefono;
    document.getElementById("modalTitle").innerText = "Editar Proveedor";
    editIndex = i;
    openModal();
}

function del(i){
    if(!permisosModulo.bitEliminar) return alert("❌ No tienes permiso para eliminar.");
    if(confirm("¿Seguro que deseas eliminar este proveedor?")){
        data.splice(i,1);
        persist();
        render();
    }
}

// --- 🛡️ INICIALIZACIÓN SINCRÓNICA ---
document.addEventListener("DOMContentLoaded", async () => {
    await cargarPermisos(); // Primero consultamos los bits del perfil
    render();               // Luego dibujamos la interfaz
});
</script>

</body>
</html>