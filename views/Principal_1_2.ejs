<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>CRUD Proveedores</title>
    <link rel="stylesheet" href="/css/Principal_1.1.css">
    <link rel="stylesheet" href="/css/breadcrums.css"> 
    <style>
        .pagination { margin-top: 15px; display: flex; gap: 10px; align-items: center; justify-content: center; }
        .pagination button { padding: 5px 12px; cursor: pointer; border: 1px solid #ccc; background: #fff; border-radius: 4px; }
        .pagination button:disabled { opacity: 0.5; cursor: not-allowed; }
        /* Evita el parpadeo ocultando el botón nuevo por defecto en el CSS */
        #btnNuevo { display: none; }
    </style>
</head>

<body>

<%- include('partials/breadcrumb') %>

<div class="top-bar">
    <input type="text" id="search" placeholder="Buscar proveedor...">
    
    <select id="rows">
        <option value="5">5</option>
        <option value="10" selected>10</option>
        <option value="15">15</option>
    </select>

    <button id="btnNuevo" class="btn-add" onclick="openModal()">+</button>
</div>

<table>
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Apellidos</th>
            <th>Teléfono</th>
            <th>Correo</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody id="tableBody"></tbody>
</table>

<div class="pagination">
    <button id="btnFirst" onclick="firstPage()">⏮</button>
    <button id="btnPrev" onclick="prevPage()">◀</button>
    <span id="pageInfo"></span>
    <button id="btnNext" onclick="nextPage()">▶</button>
    <button id="btnLast" onclick="lastPage()">⏭</button>
</div>

<div class="modal" id="modal" style="display: none;">
    <div class="modal-content">
        <h3 id="modalTitle">Registrar Proveedor</h3>
        
        <label>Nombre</label>
        <input id="nombreProveedor" placeholder="Ej. Juan" maxlength="50" oninput="this.value = this.value.replace(/[0-9]/g, '')">
        
        <label>Apellidos</label>
        <input id="ApellidosProveedor" placeholder="Ej. Pérez" maxlength="50" oninput="this.value = this.value.replace(/[0-9]/g, '')">
        
        <label>Correo Electrónico</label>
        <input id="Correo" type="email" placeholder="correo@ejemplo.com">
        
        <label>Teléfono</label>
        <input id="Telefono" placeholder="Solo números" maxlength="15" oninput="this.value = this.value.replace(/[^0-9]/g, '')">
        
        <div class="acciones-modal">
            <button class="btn-save" onclick="save()">Guardar</button>
            <button class="btn-cancel" onclick="closeModal()">Cancelar</button>
        </div>
    </div>
</div>

<script src="/js/breadcrums.js"></script> 

<script>
let data = JSON.parse(localStorage.getItem("proveedores")) || [];
let page = 1;
let rows = 10;
let editIndex = null;

// --- 🛡️ ESTADO GLOBAL ---
let permisosModulo = {
    bitAgregar: 0, bitEditar: 0, bitConsulta: 0, bitEliminar: 0, bitDetalle: 0,
    bitAdministrador: 0 
};

// --- 🛡️ CARGAR PERMISOS (ASÍNCRONO) ---
async function cargarPermisos() {
    try {
        // Asegúrate que el nombre 'Principal_1.2' coincida con tu DB
        const res = await fetch('/api/permisosPerfil/mis-permisos?modulo=Principal_1.2');
        const result = await res.json();
        permisosModulo = result;
        
        const puedeAgregar = permisosModulo.bitAdministrador || permisosModulo.bitAgregar;
        const btn = document.getElementById('btnNuevo');
        if(btn) btn.style.display = puedeAgregar ? 'block' : 'none';

    } catch (error) {
        console.error("Error cargando permisos de Proveedores:", error);
    }
}

function persist(){
    localStorage.setItem("proveedores", JSON.stringify(data));
}

function getFilteredData(){
    let search = (document.getElementById("search").value || "").toLowerCase();
    return data.filter(d =>
        (d.nombreProveedor || "").toLowerCase().includes(search) ||
        (d.apellidosProveedor || "").toLowerCase().includes(search) ||
        (d.correo || "").toLowerCase().includes(search) ||
        (d.telefono || "").toString().includes(search)
    );
}

function render(){
    let tbody = document.getElementById("tableBody");
    if (!tbody) return;
    tbody.innerHTML = "";

    let filtered = getFilteredData();
    let total = Math.ceil(filtered.length / rows) || 1;

    if(page > total) page = total || 1;

    let start = (page-1)*rows;
    let paginated = filtered.slice(start, start+rows);

    paginated.forEach((d) => {
        let realIndex = data.indexOf(d); 
        
        const puedeEditar = permisosModulo.bitAdministrador || permisosModulo.bitEditar;
        const puedeEliminar = permisosModulo.bitAdministrador || permisosModulo.bitEliminar;

        let botonesAccion = "";
        if (puedeEditar) {
            botonesAccion += `<button class="btn-edit" onclick="edit(${realIndex})">✏️</button> `;
        }
        if (puedeEliminar) {
            botonesAccion += `<button class="btn-delete" onclick="del(${realIndex})">🗑</button>`;
        }
        if (!puedeEditar && !puedeEliminar) {
            botonesAccion = '<span style="color:gray; font-size:11px;">Solo lectura</span>';
        }

        tbody.innerHTML += `
        <tr>
            <td>${d.nombreProveedor}</td>
            <td>${d.apellidosProveedor}</td>
            <td>${d.telefono}</td>
            <td>${d.correo}</td>
            <td>${botonesAccion}</td>
        </tr>`;
    });

    document.getElementById("pageInfo").innerText = `Página ${page} de ${total}`;
    document.getElementById("btnPrev").disabled = (page === 1);
    document.getElementById("btnFirst").disabled = (page === 1);
    document.getElementById("btnNext").disabled = (page === total);
    document.getElementById("btnLast").disabled = (page === total);
}

// --- NAVEGACIÓN ---
function firstPage() { page = 1; render(); }
function prevPage() { if (page > 1) { page--; render(); } }
function nextPage() { 
    let total = Math.ceil(getFilteredData().length / rows) || 1;
    if (page < total) { page++; render(); } 
}
function lastPage() { 
    page = Math.ceil(getFilteredData().length / rows) || 1; 
    render(); 
}

// --- MODAL ---
function openModal() { document.getElementById("modal").style.display = "flex"; }
function closeModal() {
    document.getElementById("modal").style.display = "none";
    document.getElementById("nombreProveedor").value = "";
    document.getElementById("ApellidosProveedor").value = "";
    document.getElementById("Correo").value = "";
    document.getElementById("Telefono").value = "";
    document.getElementById("modalTitle").innerText = "Registrar Proveedor";
    editIndex = null;
}

function save(){
    const puedeEditar = permisosModulo.bitAdministrador || permisosModulo.bitEditar;
    const puedeAgregar = permisosModulo.bitAdministrador || permisosModulo.bitAgregar;

    if(editIndex !== null && !puedeEditar) return alert("❌ No tienes permiso para editar.");
    if(editIndex === null && !puedeAgregar) return alert("❌ No tienes permiso para registrar.");

    const nombre = document.getElementById("nombreProveedor").value.trim();
    const apellidos = document.getElementById("ApellidosProveedor").value.trim();
    const correo = document.getElementById("Correo").value.trim();
    const telefono = document.getElementById("Telefono").value.trim();

    if(!nombre || !apellidos || !correo || !telefono) return alert("❌ Campos obligatorios.");

    let obj = { nombreProveedor: nombre, apellidosProveedor: apellidos, correo: correo, telefono: telefono };

    if(editIndex !== null) data[editIndex] = obj;
    else data.push(obj);

    persist();
    closeModal();
    render();
}

function edit(i){
    let d = data[i];
    document.getElementById("nombreProveedor").value = d.nombreProveedor;
    document.getElementById("ApellidosProveedor").value = d.apellidosProveedor;
    document.getElementById("Correo").value = d.correo;
    document.getElementById("Telefono").value = d.telefono;
    document.getElementById("modalTitle").innerText = "Editar Proveedor";
    editIndex = i;
    openModal();
}

function del(i){
    if(!(permisosModulo.bitAdministrador || permisosModulo.bitEliminar)) return alert("❌ Sin permiso.");
    if(confirm("¿Eliminar proveedor?")){
        data.splice(i,1);
        persist();
        render();
    }
}

// Listeners
document.getElementById("search").addEventListener("input", () => { page = 1; render(); });
document.getElementById("rows").addEventListener("change", (e) => { rows = parseInt(e.target.value); page = 1; render(); });

// --- 🚀 INICIALIZACIÓN SINCRONIZADA ---
document.addEventListener("DOMContentLoaded", async () => {
    // 1. Esperamos obligatoriamente a los permisos del servidor
    await cargarPermisos(); 
    // 2. Renderizamos la tabla sabiendo ya qué botones mostrar
    render(); 
});
</script>
</body>
</html>