<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>CRUD Transportes</title>

<link rel="stylesheet" href="/css/Principal_1.1.css">
<link rel="stylesheet" href="/css/breadcrums.css"> 

</head>

<body>

<%- include('partials/breadcrumb') %>

<div class="top-bar">
    <input type="text" id="search" placeholder="Buscar...">
    
    <select id="rows">
        <option value="5">5</option>
        <option value="10" selected>10</option>
        <option value="15">15</option>
    </select>

    <button class="btn-add" onclick="openModal()">+</button>
</div>

<table>
<thead>
<tr>
    <th>Placas</th>
    <th>Marca</th>
    <th>Modelo</th>
    <th>Año</th>
    <th>Acciones</th>
</tr>
</thead>
<tbody id="tableBody"></tbody>
</table>

<div class="pagination">
    <button onclick="firstPage()">⏮</button>
    <button onclick="prevPage()">◀</button>
    
    <span id="pageInfo"></span>
    
    <button onclick="nextPage()">▶</button>
    <button onclick="lastPage()">⏭</button>
</div>

<!-- MODAL -->
<div class="modal" id="modal">
    <div class="modal-content">
        <h3>Registrar Transporte</h3>
        <input id="placas" placeholder="Placas">
        <input id="marca" placeholder="Marca">
        <input id="modelo" placeholder="Modelo">
        <input id="year" type="number" placeholder="Año">        
        <button onclick="save()">Guardar</button>
        <button onclick="closeModal()">Cancelar</button>
    </div>
</div>

<script src="/js/breadcrums.js"></script> 

<script>
let data = JSON.parse(localStorage.getItem("transportes")) || [];
let page = 1;
let rows = 10;
let editIndex = null;

/* GUARDAR */
function persist(){
    localStorage.setItem("transportes", JSON.stringify(data));
}

/* TOTAL PAGINAS */
function totalPages(filteredLength){
    return Math.ceil(filteredLength / rows) || 1;
}

/* FILTRO */
function getFilteredData(){
    let search = document.getElementById("search").value.toLowerCase();

    return data.filter(d =>
        d.placas.toLowerCase().includes(search) ||
        d.marca.toLowerCase().includes(search) ||
        d.modelo.toLowerCase().includes(search) ||
        d.year.toString().includes(search)
    );
}

/* RENDER */
function render(){
    let tbody = document.getElementById("tableBody");
    tbody.innerHTML = "";

    let filtered = getFilteredData();

    let start = (page-1)*rows;
    let paginated = filtered.slice(start, start+rows);

    paginated.forEach((d,i)=>{
        tbody.innerHTML += `
        <tr>
            <td>${d.placas}</td>
            <td>${d.marca}</td>
            <td>${d.modelo}</td>
            <td>${d.year}</td>
            <td>
                <button class="btn-edit" onclick="edit(${start+i})">✏️</button>
                <button class="btn-delete" onclick="del(${start+i})">🗑</button>
            </td>
        </tr>`;
    });

    let total = totalPages(filtered.length);

    if(page > total) page = total;

    document.getElementById("pageInfo").innerText =
        "Página " + page + " de " + total;
}

/* PAGINACIÓN */
function nextPage(){
    let filtered = getFilteredData();
    if(page < totalPages(filtered.length)){
        page++;
        render();
    }
}

function prevPage(){
    if(page > 1){
        page--;
        render();
    }
}

function firstPage(){
    page = 1;
    render();
}

function lastPage(){
    let filtered = getFilteredData();
    page = totalPages(filtered.length);
    render();
}

/* FILAS */
document.getElementById("rows").addEventListener("change", e=>{
    rows = parseInt(e.target.value);
    page = 1;
    render();
});

/* BUSCAR */
document.getElementById("search").addEventListener("input", ()=>{
    page = 1;
    render();
});

/* MODAL */
function openModal(){
    document.getElementById("modal").style.display="flex";
}

function closeModal(){
    document.getElementById("modal").style.display="none";
    clear();
}

function clear(){
    document.getElementById("placas").value="";
    document.getElementById("marca").value="";
    document.getElementById("modelo").value="";
    document.getElementById("year").value="";
    editIndex = null;
}

/* GUARDAR */
function save(){
    let obj = {
        placas: document.getElementById("placas").value,
        marca: document.getElementById("marca").value,
        modelo: document.getElementById("modelo").value,
        year: document.getElementById("year").value
    };

    if(editIndex !== null){
        data[editIndex] = obj;
    }else{
        data.push(obj);
    }

    persist();
    closeModal();
    render();
}

/* EDITAR */
function edit(i){
    let d = data[i];

    document.getElementById("placas").value = d.placas;
    document.getElementById("marca").value = d.marca;
    document.getElementById("modelo").value = d.modelo;
    document.getElementById("year").value = d.year;

    editIndex = i;
    openModal();
}

/* ELIMINAR */
function del(i){
    if(confirm("¿Eliminar transporte?")){
        data.splice(i,1);
        persist();
        render();
    }
}

render();
</script>

</body>
</html>