<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>CRUD Transportes</title>
<link rel="stylesheet" href="/css/Principal_1.1.css">
<link rel="stylesheet" href="/css/breadcrums.css"> 
<style>
    /* Estilo para asegurar la visualización de la paginación */
    .pagination { margin-top: 15px; display: flex; gap: 10px; align-items: center; justify-content: center; }
    .pagination button { padding: 5px 12px; cursor: pointer; border: 1px solid #ccc; background: #fff; border-radius: 4px; }
    .pagination button:disabled { opacity: 0.5; cursor: not-allowed; }
</style>
</head>

<body>

<%- include('partials/breadcrumb') %>

<div class="top-bar">
    <input type="text" id="search" placeholder="Buscar por placa, marca o modelo...">
    
    <select id="rows">
        <option value="5">5</option>
        <option value="10" selected>10</option>
        <option value="15">15</option>
    </select>
    <button id="btnNuevo" class="btn-add" onclick="openModal()">+</button>
</div>

<table>
<thead>
<tr>
    <th>Placas</th>
    <th>Marca</th>
    <th>Modelo</th>
    <th>Año</th>
    <th>Acciones</th>
</tr>
</thead>
<tbody id="tableBody"></tbody>
</table>

<div class="pagination">
    <button id="btnFirst" onclick="firstPage()">⏮</button>
    <button id="btnPrev" onclick="prevPage()">◀</button>
    <span id="pageInfo"></span>
    <button id="btnNext" onclick="nextPage()">▶</button>
    <button id="btnLast" onclick="lastPage()">⏭</button>
</div>

<div class="modal" id="modal">
    <div class="modal-content">
        <h3 id="modalTitle">Registrar Transporte</h3>
        
        <label>Placas</label>
        <input id="placas" placeholder="Ej. ABC-1234" 
               oninput="this.value = this.value.toUpperCase().replace(/[^A-Z0-9-]/g, '')" maxlength="10">
        
        <label>Marca</label>
        <input id="marca" placeholder="Ej. Toyota" 
         maxlength="50" 
               oninput="this.value = this.value.replace(/[0-9]/g, '')">
        
        <label>Modelo</label>
        <input id="modelo" placeholder="Ej. Hilux">
        
        <label>Año</label>
        <input id="year" type="number" placeholder="2024" min="1950" max="2027"
               oninput="if(this.value.length > 4) this.value = this.value.slice(0,4)">
        
        <div class="acciones-modal">
            <button class="btn-save" onclick="save()">Guardar</button>
            <button class="btn-cancel" onclick="closeModal()">Cancelar</button>
        </div>
    </div>
</div>

<script>
let data = JSON.parse(localStorage.getItem("transportes")) || [];
let page = 1;
let rows = 10;
let editIndex = null;

// --- 🛡️ ESTADO GLOBAL DE PERMISOS ---
// Inicializamos todo en 0 para que por defecto sea "Solo Lectura" hasta que el servidor responda
let permisosModulo = {
    bitAgregar: 0, bitEditar: 0, bitConsulta: 0, bitEliminar: 0, bitDetalle: 0,
    bitAdministrador: 0 
};

// --- 🛡️ CARGAR PERMISOS ---
async function cargarPermisos() {
    try {
        // IMPORTANTE: Verifica que 'Principal_2_1' sea el nombre exacto en tu tabla de Modulos
        const res = await fetch('/api/permisosPerfil/mis-permisos?modulo=Principal_2_1');
        const json = await res.json();
        
        if (json) {
            permisosModulo = json;
            console.log("Permisos cargados para Transportes:", permisosModulo);
        }

        // Aplicar visibilidad del botón nuevo inmediatamente
        const puedeAgregar = permisosModulo.bitAdministrador || permisosModulo.bitAgregar;
        const btn = document.getElementById('btnNuevo');
        if(btn) btn.style.display = puedeAgregar ? 'block' : 'none';
        
    } catch (error) {
        console.error("Error crítico cargando permisos de Transportes:", error);
        // En caso de error, mantenemos permisos en 0 por seguridad
    }
}

// ... (persist, totalPages, getFilteredData se mantienen igual) ...

function render(){
    let tbody = document.getElementById("tableBody");
    tbody.innerHTML = "";
    let filtered = getFilteredData();
    let total = totalPages(filtered.length);

    if(page > total) page = total || 1;

    let start = (page-1)*rows;
    let paginated = filtered.slice(start, start+rows);

    // Definimos las constantes de permiso antes del loop para mayor eficiencia
    const puedeEditar = permisosModulo.bitAdministrador || permisosModulo.bitEditar;
    const puedeEliminar = permisosModulo.bitAdministrador || permisosModulo.bitEliminar;

    paginated.forEach((d) => {
        let realIndex = data.indexOf(d); 
        
        let botonesAccion = "";
        if (puedeEditar) {
            botonesAccion += `<button class="btn-edit" onclick="edit(${realIndex})">✏️</button> `;
        }
        if (puedeEliminar) {
            botonesAccion += `<button class="btn-delete" onclick="del(${realIndex})">🗑</button>`;
        }
        
        if (!puedeEditar && !puedeEliminar) {
            botonesAccion = '<span style="color:gray; font-size:11px;">Solo lectura</span>';
        }

        tbody.innerHTML += `
        <tr>
            <td>${d.placas}</td>
            <td>${d.marca}</td>
            <td>${d.modelo}</td>
            <td>${d.year}</td>
            <td>${botonesAccion}</td>
        </tr>`;
    });

    // Actualizar paginación
    document.getElementById("pageInfo").innerText = `Página ${page} de ${total}`;
    document.getElementById("btnPrev").disabled = (page === 1);
    document.getElementById("btnFirst").disabled = (page === 1);
    document.getElementById("btnNext").disabled = (page === total);
    document.getElementById("btnLast").disabled = (page === total);
}

// ... (Navegación y Modal Logic se mantienen igual) ...

/* 🛡️ GUARDAR PROTEGIDO */
function save(){
    // Re-validamos permisos justo antes de guardar por seguridad
    const puedeEditar = permisosModulo.bitAdministrador || permisosModulo.bitEditar;
    const puedeAgregar = permisosModulo.bitAdministrador || permisosModulo.bitAgregar;

    if(editIndex !== null && !puedeEditar) return alert("❌ Sin permiso para editar.");
    if(editIndex === null && !puedeAgregar) return alert("❌ Sin permiso para registrar.");

    // ... (Resto de la lógica de guardado) ...
}

// ... (Edit y Del se mantienen igual) ...

// --- 🛡️ INICIO CONTROLADO ---
document.addEventListener("DOMContentLoaded", async () => {
    // 1. Esperamos a que los permisos lleguen del servidor
    await cargarPermisos();
    // 2. Una vez que tenemos los bits, dibujamos la tabla
    render();
});
</script>
</body>
</html>