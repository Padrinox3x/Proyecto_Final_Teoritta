<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>CRUD Empleados Sucursal - Principal 2.2</title>
    <link rel="stylesheet" href="/css/Principal_1.1.css">
    <link rel="stylesheet" href="/css/breadcrums.css"> 
</head>

<body>

<%- include('partials/breadcrumb') %>

<div class="top-bar">
    <input type="text" id="search" placeholder="Buscar empleado sucursal...">
    
    <select id="rows">
        <option value="5">5</option>
        <option value="10" selected>10</option>
        <option value="15">15</option>
    </select>

    <button id="btnNuevo" class="btn-add" onclick="openModal()">+ Nuevo</button>
</div>

<table>
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Apellidos</th>
            <th>Teléfono</th>
            <th>Correo</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody id="tableBody"></tbody>
</table>

<div class="pagination">
    <button id="btnFirst" onclick="firstPage()">⏮</button>
    <button id="btnPrev" onclick="prevPage()">◀</button>
    <span id="pageInfo"></span>
    <button id="btnNext" onclick="nextPage()">▶</button>
    <button id="btnLast" onclick="lastPage()">⏭</button>
</div>

<div id="modal" class="modal" style="display: none;">
    <div class="modal-content">
        <h3 id="modalTitle">Registrar Empleado Sucursal</h3>

        <label>Nombre *</label>
        <input id="nombreProveedor" maxlength="50" placeholder="Ingrese el nombre">

        <label>Apellidos *</label>
        <input id="ApellidosProveedor" maxlength="50" placeholder="Ingrese los apellidos">

        <label>Correo</label>
        <input id="Correo" type="email" placeholder="ejemplo@correo.com">

        <label>Teléfono</label>
        <input id="Telefono" maxlength="15" placeholder="Número de teléfono">

        <div class="acciones-modal">
            <button class="btn-save" onclick="save()">Guardar</button>
            <button class="btn-cancel" onclick="closeModal()">Cancelar</button>
        </div>
    </div>
</div>

<script src="/js/breadcrums.js"></script>

<script>
// =========================
// DATA - Inicializar con datos de ejemplo para Empleados Sucursal
// =========================
let data = [];
let page = 1;
let rows = 10;
let editIndex = null;

// Inicializar datos de ejemplo si no hay datos
function inicializarDatosEjemplo() {
    const stored = localStorage.getItem("empleados_sucursal");
    
    if (stored && JSON.parse(stored).length > 0) {
        data = JSON.parse(stored);
        console.log("📦 Datos cargados desde localStorage:", data.length, "empleados sucursal");
    } else {
        // Datos de ejemplo para empleados de sucursal
        data = [
            {
                nombreProveedor: "Laura",
                apellidosProveedor: "García Méndez",
                correo: "laura.garcia@sucursal.com",
                telefono: "5551112223"
            },
            {
                nombreProveedor: "Carlos",
                apellidosProveedor: "Hernández López",
                correo: "carlos.hernandez@sucursal.com",
                telefono: "5553334445"
            },
            {
                nombreProveedor: "Andrea",
                apellidosProveedor: "Martínez Ruiz",
                correo: "andrea.martinez@sucursal.com",
                telefono: "5555556667"
            },
            {
                nombreProveedor: "Javier",
                apellidosProveedor: "Sánchez Torres",
                correo: "javier.sanchez@sucursal.com",
                telefono: "5557778889"
            },
            {
                nombreProveedor: "Patricia",
                apellidosProveedor: "Ramírez Castro",
                correo: "patricia.ramirez@sucursal.com",
                telefono: "5559990001"
            },
            {
                nombreProveedor: "Roberto",
                apellidosProveedor: "Flores Navarro",
                correo: "roberto.flores@sucursal.com",
                telefono: "5552223334"
            }
        ];
        persist();
        console.log("📝 Datos de ejemplo creados:", data.length, "empleados sucursal");
    }
}

// =========================
// PERMISOS - Principal_2.2
// =========================
let permisosModulo = {
    bitAgregar: 0,
    bitEditar: 0,
    bitConsulta: 1,
    bitEliminar: 0,
    bitDetalle: 0,
    bitAdministrador: 0
};

// =========================
// CARGAR PERMISOS - CON TIMESTAMP PARA EVITAR CACHE
// =========================
async function cargarPermisos() {
    try {
        // ✅ Usar Principal_2.2 y agregar timestamp para evitar caché
        const res = await fetch('/api/permisosPerfil/mis-permisos?modulo=Principal_2.2&t=' + Date.now());

        if (res.ok) {
            const result = await res.json();
            if (result) {
                permisosModulo = result;
                console.log("✅ Permisos cargados para Principal_2.2 (Empleados Sucursal):", permisosModulo);
                console.log("¿Puede agregar?", permisosModulo.bitAdministrador || permisosModulo.bitAgregar);
                console.log("¿Puede editar?", permisosModulo.bitAdministrador || permisosModulo.bitEditar);
                console.log("¿Puede eliminar?", permisosModulo.bitAdministrador || permisosModulo.bitEliminar);
            }
        } else {
            console.warn("⚠️ Sin permisos en BD → modo lectura");
            // Mantener permisos por defecto
        }

    } catch (error) {
        console.error("❌ Error cargando permisos:", error);
    }

    // Actualizar UI según permisos
    actualizarUIporPermisos();
    return true;
}

// Función para actualizar la UI
function actualizarUIporPermisos() {
    const puedeAgregar = permisosModulo.bitAdministrador || permisosModulo.bitAgregar;
    const btnNuevo = document.getElementById("btnNuevo");
    if (btnNuevo) {
        btnNuevo.style.display = puedeAgregar ? "block" : "none";
        console.log("Botón Nuevo visible?", puedeAgregar);
    }
    
    // Re-renderizar la tabla
    if (typeof render === 'function') {
        render();
    }
}

// Validar permiso específico en tiempo real
async function validarPermiso(tipoAccion) {
    // Recargar permisos para asegurar datos actualizados
    await cargarPermisos();
    
    let tienePermiso = false;
    switch(tipoAccion) {
        case 'agregar':
            tienePermiso = permisosModulo.bitAdministrador || permisosModulo.bitAgregar;
            break;
        case 'editar':
            tienePermiso = permisosModulo.bitAdministrador || permisosModulo.bitEditar;
            break;
        case 'eliminar':
            tienePermiso = permisosModulo.bitAdministrador || permisosModulo.bitEliminar;
            break;
        default:
            tienePermiso = true;
    }
    
    if (!tienePermiso) {
        alert(`❌ No tienes permiso para ${tipoAccion} empleados de sucursal`);
        return false;
    }
    return true;
}

// =========================
// STORAGE - Usar clave específica para empleados sucursal
// =========================
function persist() {
    localStorage.setItem("empleados_sucursal", JSON.stringify(data));
    console.log("💾 Datos guardados:", data.length, "empleados sucursal");
}

// =========================
// FILTRO
// =========================
function getFilteredData() {
    const searchInput = document.getElementById("search");
    const search = searchInput ? (searchInput.value || "").toLowerCase() : "";

    if (!search) return data;
    
    return data.filter(d =>
        (d.nombreProveedor || "").toLowerCase().includes(search) ||
        (d.apellidosProveedor || "").toLowerCase().includes(search) ||
        (d.correo || "").toLowerCase().includes(search) ||
        (d.telefono || "").toString().includes(search)
    );
}

// =========================
// RENDER - Versión mejorada
// =========================
function render() {
    const tbody = document.getElementById("tableBody");
    if (!tbody) return;
    
    // Verificar permisos de consulta
    if (!(permisosModulo.bitAdministrador || permisosModulo.bitConsulta)) {
        tbody.innerHTML = '<tr><td colspan="5" style="text-align: center;">No tienes permisos para ver este módulo</td></tr>';
        return;
    }

    const filtered = getFilteredData();
    
    if (filtered.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" style="text-align: center;">No hay empleados registrados en la sucursal</td></tr>';
        const pageInfo = document.getElementById("pageInfo");
        if (pageInfo) pageInfo.innerText = `Página 1 de 1`;
        return;
    }
    
    const total = Math.ceil(filtered.length / rows) || 1;
    if (page > total) page = total;
    if (page < 1) page = 1;

    const start = (page - 1) * rows;
    const paginated = filtered.slice(start, start + rows);
    
    tbody.innerHTML = "";

    paginated.forEach((item) => {
        // Encontrar el índice real en data
        const realIndex = data.findIndex(d => 
            d.nombreProveedor === item.nombreProveedor && 
            d.apellidosProveedor === item.apellidosProveedor &&
            d.correo === item.correo
        );
        
        const puedeEditar = permisosModulo.bitAdministrador || permisosModulo.bitEditar;
        const puedeEliminar = permisosModulo.bitAdministrador || permisosModulo.bitEliminar;

        let acciones = "";
        
        if (puedeEditar) {
            acciones += `<button class="edit-btn" onclick="edit(${realIndex})">✏️ Editar</button>`;
        }
        
        if (puedeEliminar) {
            acciones += `<button class="delete-btn" onclick="del(${realIndex})">🗑 Eliminar</button>`;
        }
        
        if (!acciones) {
            acciones = `<span style="color:gray;">Solo lectura</span>`;
        }

        const row = document.createElement('tr');
        row.innerHTML = `
            <td>${escapeHtml(item.nombreProveedor || '')}</td>
            <td>${escapeHtml(item.apellidosProveedor || '')}</td>
            <td>${escapeHtml(item.telefono || '')}</td>
            <td>${escapeHtml(item.correo || '')}</td>
            <td>${acciones}</td>
        `;
        tbody.appendChild(row);
    });

    const pageInfo = document.getElementById("pageInfo");
    if (pageInfo) pageInfo.innerText = `Página ${page} de ${total}`;
    
    // Actualizar estado de botones de paginación
    const btnFirst = document.getElementById('btnFirst');
    const btnPrev = document.getElementById('btnPrev');
    const btnNext = document.getElementById('btnNext');
    const btnLast = document.getElementById('btnLast');
    
    if (btnFirst) btnFirst.disabled = page <= 1;
    if (btnPrev) btnPrev.disabled = page <= 1;
    if (btnNext) btnNext.disabled = page >= total;
    if (btnLast) btnLast.disabled = page >= total;
}

// Función para escapar HTML y prevenir XSS
function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

// =========================
// PAGINACIÓN
// =========================
function firstPage() { page = 1; render(); }
function prevPage() { if (page > 1) { page--; render(); } }
function nextPage() { 
    const total = Math.ceil(getFilteredData().length / rows) || 1;
    if (page < total) { page++; render(); } 
}
function lastPage() { 
    const total = Math.ceil(getFilteredData().length / rows) || 1;
    page = total; 
    render(); 
}

// =========================
// MODAL
// =========================
async function openModal() {
    const tienePermiso = await validarPermiso('agregar');
    if (!tienePermiso) return;
    
    const modal = document.getElementById("modal");
    if (modal) {
        modal.style.display = "flex";
        const modalTitle = document.getElementById("modalTitle");
        if (modalTitle) modalTitle.textContent = "Registrar Empleado Sucursal";
    }
    editIndex = null;
    
    // Limpiar campos
    const campos = ["nombreProveedor", "ApellidosProveedor", "Correo", "Telefono"];
    campos.forEach(campo => {
        const input = document.getElementById(campo);
        if (input) input.value = "";
    });
}

function closeModal() {
    const modal = document.getElementById("modal");
    if (modal) modal.style.display = "none";
    
    const campos = ["nombreProveedor", "ApellidosProveedor", "Correo", "Telefono"];
    campos.forEach(campo => {
        const input = document.getElementById(campo);
        if (input) input.value = "";
    });
    editIndex = null;
}

// =========================
// CRUD
// =========================
async function save() {
    const isEdit = editIndex !== null;
    const tipoAccion = isEdit ? 'editar' : 'agregar';
    
    // Validar permisos antes de guardar
    const tienePermiso = await validarPermiso(tipoAccion);
    if (!tienePermiso) return;
    
    const nombre = document.getElementById("nombreProveedor")?.value.trim() || "";
    const apellidos = document.getElementById("ApellidosProveedor")?.value.trim() || "";

    if (!nombre || !apellidos) {
        alert("❌ Nombre y apellidos son campos obligatorios");
        return;
    }
    
    // Validar correo si se ingresó
    const correo = document.getElementById("Correo")?.value.trim() || "";
    if (correo && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(correo)) {
        alert("❌ Ingrese un correo electrónico válido");
        return;
    }

    const obj = {
        nombreProveedor: nombre,
        apellidosProveedor: apellidos,
        correo: correo,
        telefono: document.getElementById("Telefono")?.value.trim() || ""
    };

    if (editIndex !== null && editIndex >= 0 && editIndex < data.length) {
        data[editIndex] = obj;
        console.log("✏️ Empleado sucursal editado en índice:", editIndex);
    } else if (editIndex === null) {
        data.push(obj);
        console.log("➕ Nuevo empleado sucursal agregado");
    } else {
        console.error("Índice inválido para edición:", editIndex);
        return;
    }

    persist();
    closeModal();
    render();
}

async function edit(i) {
    const tienePermiso = await validarPermiso('editar');
    if (!tienePermiso) return;
    
    if (i < 0 || i >= data.length) {
        console.error("Índice inválido para editar:", i);
        alert("Error: No se encuentra el empleado");
        return;
    }
    
    editIndex = i;
    const d = data[i];

    const campos = {
        nombreProveedor: d.nombreProveedor || '',
        ApellidosProveedor: d.apellidosProveedor || '',
        Correo: d.correo || '',
        Telefono: d.telefono || ''
    };
    
    for (const [id, value] of Object.entries(campos)) {
        const input = document.getElementById(id);
        if (input) input.value = value;
    }
    
    const modal = document.getElementById("modal");
    if (modal) {
        modal.style.display = "flex";
        const modalTitle = document.getElementById("modalTitle");
        if (modalTitle) modalTitle.textContent = "Editar Empleado Sucursal";
    }
}

async function del(i) {
    const tienePermiso = await validarPermiso('eliminar');
    if (!tienePermiso) return;
    
    if (confirm("¿Está seguro de eliminar este empleado de sucursal?")) {
        data.splice(i, 1);
        persist();
        
        // Ajustar página si es necesario
        const filtered = getFilteredData();
        const totalPages = Math.ceil(filtered.length / rows) || 1;
        if (page > totalPages) page = totalPages;
        if (page < 1) page = 1;
        
        render();
        console.log("🗑 Empleado sucursal eliminado");
    }
}

// =========================
// EVENTOS
// =========================
function setupEventListeners() {
    const searchInput = document.getElementById("search");
    if (searchInput) {
        searchInput.addEventListener("input", () => { 
            page = 1; 
            render(); 
        });
    }
    
    const rowsSelect = document.getElementById("rows");
    if (rowsSelect) {
        rowsSelect.addEventListener("change", (e) => { 
            rows = parseInt(e.target.value); 
            page = 1; 
            render(); 
        });
    }
}

// =========================
// INIT
// =========================
document.addEventListener("DOMContentLoaded", async () => {
    console.log("🚀 Inicializando Principal_2.2 (Empleados Sucursal)...");
    
    // Inicializar datos
    inicializarDatosEjemplo();
    
    // Configurar event listeners
    setupEventListeners();
    
    // Cargar permisos (esto también actualizará la UI)
    await cargarPermisos();
    
    // Renderizar la tabla
    render();
    
    console.log("✅ Inicialización completada");
    console.log("Permisos finales:", permisosModulo);
});
</script>

</body>
</html>