<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>CRUD Sucursales</title>
<link rel="stylesheet" href="/css/Principal_1.1.css">
<link rel="stylesheet" href="/css/breadcrums.css"> 
</head>

<body>

<%- include('partials/breadcrumb') %>

<div class="top-bar">
    <input type="text" id="search" placeholder="Buscar por nombre, dirección o ciudad...">
    
    <select id="rows">
        <option value="5">5</option>
        <option value="10" selected>10</option>
        <option value="15">15</option>
    </select>

    <button class="btn-add" onclick="openModal()">+</button>
</div>

<table>
<thead>
<tr>
    <th>Nombre</th>
    <th>Dirección</th>
    <th>Ciudad</th>
    <th>Acciones</th>
</tr>
</thead>
<tbody id="tableBody"></tbody>
</table>

<div class="pagination">
    <button onclick="firstPage()">⏮</button>
    <button onclick="prevPage()">◀</button>
    <span id="pageInfo"></span>
    <button onclick="nextPage()">▶</button>
    <button onclick="lastPage()">⏭</button>
</div>

<div class="modal" id="modal">
    <div class="modal-content">
        <h3 id="modalTitle">Registrar Sucursal</h3>
        
        <label>Nombre de la Sucursal</label>
        <input id="nombre" placeholder="Ej. Norte Principal" 
               oninput="this.value = this.value.replace(/[0-9]/g, '')">
        
        <label>Dirección</label>
        <input id="direccion" placeholder="Ej. Av. Siempre Viva 123">
        
        <label>Ciudad</label>
        <input id="ciudad" placeholder="Ej. CDMX" 
               oninput="this.value = this.value.replace(/[0-9]/g, '')">
        
        <div class="acciones-modal">
            <button class="btn-save" onclick="save()">Guardar</button>
            <button class="btn-cancel" onclick="closeModal()">Cancelar</button>
        </div>
    </div>
</div>

<script src="/js/breadcrums.js"></script> 

<script>
let data = JSON.parse(localStorage.getItem("sucursales")) || [];
let page = 1;
let rows = 10;
let editIndex = null;

function persist(){
    localStorage.setItem("sucursales", JSON.stringify(data));
}

function totalPages(filteredLength){
    return Math.ceil(filteredLength / rows) || 1;
}

function getFilteredData(){
    let search = document.getElementById("search").value.toLowerCase();
    return data.filter(d =>
        d.nombre.toLowerCase().includes(search) ||
        d.direccion.toLowerCase().includes(search) ||
        d.ciudad.toLowerCase().includes(search)
    );
}

function render(){
    let tbody = document.getElementById("tableBody");
    tbody.innerHTML = "";
    let filtered = getFilteredData();
    let start = (page-1)*rows;
    let paginated = filtered.slice(start, start+rows);

    paginated.forEach((d, i) => {
        let realIndex = data.indexOf(d); 
        tbody.innerHTML += `
        <tr>
            <td>${d.nombre}</td>
            <td>${d.direccion}</td>
            <td>${d.ciudad}</td>
            <td>
                <button class="btn-edit" onclick="edit(${realIndex})">✏️</button>
                <button class="btn-delete" onclick="del(${realIndex})">🗑</button>
            </td>
        </tr>`;
    });

    let total = totalPages(filtered.length);
    if(page > total && total > 0) page = total;
    document.getElementById("pageInfo").innerText = `Página ${page} de ${total}`;
}

/* NAVEGACIÓN */
function nextPage(){ if(page < totalPages(getFilteredData().length)){ page++; render(); } }
function prevPage(){ if(page > 1){ page--; render(); } }
function firstPage(){ page = 1; render(); }
function lastPage(){ page = totalPages(getFilteredData().length); render(); }

document.getElementById("rows").addEventListener("change", e => {
    rows = parseInt(e.target.value);
    page = 1;
    render();
});

document.getElementById("search").addEventListener("input", () => {
    page = 1;
    render();
});

/* MODAL LOGIC */
function openModal(){ document.getElementById("modal").style.display="flex"; }

function closeModal(){
    document.getElementById("modal").style.display="none";
    clear();
}

function clear(){
    document.getElementById("nombre").value="";
    document.getElementById("direccion").value="";
    document.getElementById("ciudad").value="";
    document.getElementById("modalTitle").innerText = "Registrar Sucursal";
    editIndex = null;
}

/* 🛡️ GUARDAR CON VALIDACIONES */
function save(){
    const nombre = document.getElementById("nombre").value.trim();
    const direccion = document.getElementById("direccion").value.trim();
    const ciudad = document.getElementById("ciudad").value.trim();

    // 1. Campos obligatorios
    if(!nombre || !direccion || !ciudad){
        alert("❌ Todos los campos son obligatorios.");
        return;
    }

    // 2. Validación de longitud
    if(nombre.length < 3 || ciudad.length < 3){
        alert("❌ El nombre y la ciudad deben tener al menos 3 caracteres.");
        return;
    }

    let obj = {
        nombre: nombre,
        direccion: direccion,
        ciudad: ciudad
    };

    if(editIndex !== null){
        data[editIndex] = obj;
    }else{
        data.push(obj);
    }

    persist();
    closeModal();
    render();
}

function edit(i){
    let d = data[i];
    document.getElementById("nombre").value = d.nombre;
    document.getElementById("direccion").value = d.direccion;
    document.getElementById("ciudad").value = d.ciudad;
    document.getElementById("modalTitle").innerText = "Editar Sucursal";
    editIndex = i;
    openModal();
}

function del(i){
    if(confirm("¿Seguro que deseas eliminar esta sucursal?")){
        data.splice(i,1);
        persist();
        render();
    }
}

document.addEventListener("DOMContentLoaded", render);
</script>

</body>
</html>