<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Módulos</title>

<link rel="stylesheet" href="/css/modulo.css">
<link rel="stylesheet" href="/css/breadcrums.css"> 
</head>

<body>

<%- include('partials/breadcrumb') %>

<div class="container"> 

    <div class="toolbar">
        <input type="text" id="buscar" placeholder="Buscar...">
        <select id="limit">
            <option value="5">5</option>
            <option value="10" selected>10</option>
            <option value="20">20</option>
        </select>
        <button id="btnNuevo">➕</button>
    </div>

    <table>
        <thead>
        <tr>
            <th>Nombre Módulo</th>
            <th>Acciones</th>
        </tr>
        </thead>
        <tbody id="tablaModulo"></tbody>
    </table>

    <div class="paginacion">
        <button id="first">⏮</button>
        <button id="prev">◀</button>
        <span id="pagina"></span>
        <button id="next">▶</button>
        <button id="last">⏭</button>
    </div>

</div>

<!-- MODAL -->
<div id="modal" class="modal">
    <div class="modal-content">
        <h3>Registrar Módulo</h3>

        <form id="formModulo">
            <input type="hidden" id="id">
           <input 
    id="strNombreModulo" 
    placeholder="Nombre del módulo" 
    required 
    maxlength="50"
    oninput="this.value = this.value.replace(/[0-9]/g, '')"
    pattern="^[A-Za-zÁ-ú\sñÑ]+$"
    title="Solo letras y espacios">

            <button type="submit">Guardar</button>
            <button type="button" id="btnCancelar">Cancelar</button>
        </form>
    </div>
</div>

<script src="/js/breadcrums.js"></script> 
<script src="/js/modulo.js"></script>
<script>
let page = 1;
let rows = 10;

/* 🔥 OBTENER FILAS ACTUALES */
function getTableData(){
    return Array.from(document.querySelectorAll("#tablaPermisos tr"));
}

/* 🔍 FILTRO */
function filterData(){
    let search = document.getElementById("search").value.toLowerCase();
    let rows = getTableData();

    return rows.filter(row => 
        row.innerText.toLowerCase().includes(search)
    );
}

/* 📄 TOTAL PÁGINAS */
function totalPages(dataLength){
    return Math.ceil(dataLength / rows) || 1;
}

/* 🎨 RENDER PAGINADO */
function renderTable(){
    let allRows = getTableData();
    let filtered = filterData();

    // ocultar todas
    allRows.forEach(r => r.style.display = "none");

    let start = (page-1)*rows;
    let paginated = filtered.slice(start, start+rows);

    paginated.forEach(r => r.style.display = "");

    let total = totalPages(filtered.length);
    if(page > total) page = total;

    document.getElementById("pageInfo").innerText =
        "Página " + page + " de " + total;
}

/* ⏭ PAGINACIÓN */
function nextPage(){
    let total = totalPages(filterData().length);
    if(page < total){
        page++;
        renderTable();
    }
}

function prevPage(){
    if(page > 1){
        page--;
        renderTable();
    }
}

function firstPage(){
    page = 1;
    renderTable();
}

function lastPage(){
    page = totalPages(filterData().length);
    renderTable();
}

/* 🎛 EVENTOS */
document.getElementById("rows").addEventListener("change", e=>{
    rows = parseInt(e.target.value);
    page = 1;
    renderTable();
});

document.getElementById("search").addEventListener("input", ()=>{
    page = 1;
    renderTable();
});

/* ⏳ ESPERAR A QUE SE LLENE LA TABLA */
const observer = new MutationObserver(() => {
    renderTable();
});

observer.observe(document.getElementById("tablaPermisos"), {
    childList: true
});
</script>

</body>
</html>>