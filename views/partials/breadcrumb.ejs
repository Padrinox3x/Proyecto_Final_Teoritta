<%
const esAdmin = (permisos || []).some(p => p.bitAdministrador === 1);

const tienePermiso = (modulo) => {
  if (esAdmin) return true;

  return (permisos || []).some(p => 
    p.strNombreModulo === modulo
  );
};
%>

<nav class="menu">
  <ul>

    <% if (
      tienePermiso("Usuario") ||
      tienePermiso("Modulo") ||
      tienePermiso("Perfil") ||
      tienePermiso("Permisos_Perfil")
    ) { %>
    
    <li>
      <a href="#">Seguridad</a>
      <ul class="submenu">

        <% if (tienePermiso("Usuario")) { %>
          <li><a href="/usuario">Usuario</a></li>
        <% } %>

        <% if (tienePermiso("Modulo")) { %>
          <li><a href="/modulo">Módulo</a></li>
        <% } %>

        <% if (tienePermiso("Perfil")) { %>
          <li><a href="/perfil">Perfil</a></li>
        <% } %>

        <% if (tienePermiso("Permisos_Perfil")) { %>
          <li><a href="/permisos">Permisos_Perfil</a></li>
        <% } %>

      </ul>
    </li>
    <% } %>

    <% if (
      tienePermiso("Principal_1.1") ||
      tienePermiso("Principal_1.2")
    ) { %>

    <li>
      <a href="#">Principal 1</a>
      <ul class="submenu">

        <% if (tienePermiso("Principal_1.1")) { %>
          <li><a href="/Principal_1_1">Principal 1.1</a></li>
        <% } %>

        <% if (tienePermiso("Principal_1.2")) { %>
          <li><a href="/Principal_1_2">Principal 1.2</a></li>
        <% } %>

      </ul>
    </li>
    <% } %>

    <% if (
      tienePermiso("Principal_2.1") ||
      tienePermiso("Principal_2.2")
    ) { %>

    <li>
      <a href="#">Principal 2</a>
      <ul class="submenu">

        <% if (tienePermiso("Principal_2.1")) { %>
          <li><a href="/Principal_2_1">Principal 2.1</a></li>
        <% } %>

        <% if (tienePermiso("Principal_2.2")) { %>
          <li><a href="/Principal_2_2">Principal 2.2</a></li>
        <% } %>

      </ul>
    </li>
    <% } %>

    <li class="spacer"></li>

    <li class="user-profile-item">
      <div id="user-avatar" class="avatar-circle">
        <% if (locals.user && user.FotoUrl) { %>
          <img src="<%= user.FotoUrl %>" id="avatar-img">
        <% } else { %>
          <img src="/img/default-avatar.png" id="avatar-img">
        <% } %>
      </div>
    </li>

  </ul>
</nav>

<aside id="user-sidebar" class="user-sidebar">
  <div class="sidebar-header">
    <h3>Perfil de Usuario</h3>
    <button id="close-sidebar">&times;</button>
  </div>
  
  <div class="sidebar-content">
    <% if (locals.user) { %>
      <div class="profile-main-photo">
          <img src="<%= user.FotoUrl || '/img/default-avatar.png' %>" id="sidebar-avatar-img" alt="Avatar">
      </div>

      <div class="profile-info">
        <p><strong>Usuario:</strong> <span><%= user.strNombreUsuario %></span></p>
        <p><strong>Perfil:</strong> <span><%= user.PerfilNombre || 'Usuario' %></span></p>
        <p><strong>Correo:</strong> <span><%= user.strCorreo %></span></p>
        <p><strong>Celular:</strong> <span><%= user.strCelular || 'No registrado' %></span></p>
      </div>

      <div class="upload-section">
        <p class="upload-text">Cambiar foto de perfil</p>
        <input type="file" id="image-input" accept="image/*" style="display: none;">
        <button type="button" onclick="document.getElementById('image-input').click()" class="btn-select">Seleccionar Imagen</button>
        <button id="btn-upload" class="btn-primary">Actualizar Foto</button>
      </div>
    <% } else { %>
      <div class="profile-info">
        <p>Sesión no iniciada</p>
      </div>
    <% } %>

    <hr>
    <a href="/login" class="btn-logout">Cerrar Sesión</a>
  </div>
</aside>