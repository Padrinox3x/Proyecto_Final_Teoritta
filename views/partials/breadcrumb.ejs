<%
const esAdmin = user && (
  user.bitAdministrador == 1 || 
  user.bitAdministrador === true || 
  user.bitAdministrador === "true"
);

const tienePermiso = (modulo) => {
  if (esAdmin) return true;

  return (permisos || []).some(p => 
    (p.strNombreModulo || '')
      .trim()
      .toLowerCase() === (modulo || '').toLowerCase()
  );
};
%>

<nav class="menu">
  <ul>

    <% if (
      tienePermiso("Usuario") ||
      tienePermiso("Modulo") ||
      tienePermiso("Perfil") ||
      tienePermiso("Permisos")
    ) { %>
    
    <li>
      <a href="#">Seguridad</a>
      <ul class="submenu">

        <% if (tienePermiso("Usuario")) { %>
          <li><a href="/usuario">Usuario</a></li>
        <% } %>

        <% if (tienePermiso("Modulo")) { %>
          <li><a href="/modulo">Módulo</a></li>
        <% } %>

        <% if (tienePermiso("Perfil")) { %>
          <li><a href="/perfil">Perfil</a></li>
        <% } %>

        <% if (tienePermiso("Permisos")) { %>
          <li><a href="/permisos">Permisos</a></li>
        <% } %>

      </ul>
    </li>
    <% } %>

    <% if (
      tienePermiso("Principal_1.1") ||
      tienePermiso("Principal_1.2")
    ) { %>

    <li>
      <a href="#">Principal 1</a>
      <ul class="submenu">

        <% if (tienePermiso("Principal_1.1")) { %>
          <li><a href="/Principal_1_1">Principal 1.1</a></li>
        <% } %>

        <% if (tienePermiso("Principal_1.2")) { %>
          <li><a href="/Principal_1_2">Principal 1.2</a></li>
        <% } %>

      </ul>
    </li>
    <% } %>

    <% if (
      tienePermiso("Principal_2.1") ||
      tienePermiso("Principal_2.2")
    ) { %>

    <li>
      <a href="#">Principal 2</a>
      <ul class="submenu">

        <% if (tienePermiso("Principal_2.1")) { %>
          <li><a href="/Principal_2_1">Principal 2.1</a></li>
        <% } %>

        <% if (tienePermiso("Principal_2.2")) { %>
          <li><a href="/Principal_2_2">Principal 2.2</a></li>
        <% } %>

      </ul>
    </li>
    <% } %>

    <li class="spacer"></li>

    <li class="user-profile-item">
      <div id="user-avatar" class="avatar-circle">
        <% if (locals.user && user.FotoUrl) { %>
          <img src="<%= user.FotoUrl %>" id="avatar-img">
        <% } else { %>
          <img src="/img/default-avatar.png" id="avatar-img">
        <% } %>
      </div>
    </li>

  </ul>
</nav>