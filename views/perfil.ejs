<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Perfiles</title>
<link rel="stylesheet" href="/css/perfil.css">
<link rel="stylesheet" href="/css/breadcrums.css"> 
</head>
<body>

<%- include('partials/breadcrumb') %>

<div class="container">

    <!-- TOOLBAR -->
    <div class="toolbar">
        <input type="text" id="buscar" placeholder="Buscar perfil...">

        <select id="limit">
            <option value="5">5</option>
            <option value="10" selected>10</option>
            <option value="20">20</option>
        </select>

        <button id="btnNuevo">➕ Nuevo</button>
    </div>

    <!-- TABLA -->
    <table>
        <thead>
            <tr>
                <th>Nombre Perfil</th>
                <th>Administrador</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody id="tablaPerfil"></tbody>
    </table>

    <!-- PAGINACIÓN -->
    <div class="paginacion">
        <button id="first">⏮</button>
        <button id="prev">◀</button>
        <span id="pagina"></span>
        <button id="next">▶</button>
        <button id="last">⏭</button>
    </div>

</div>

<!-- MODAL -->
<div id="modal" class="modal">
    <div class="modal-content">

        <h2>Perfil</h2>

        <form id="formPerfil">

            <input type="hidden" id="id">

            <label>Nombre del perfil</label>
            <input id="strNombrePerfil" required>

            <label class="check">
                <input type="checkbox" id="bitAdministrador">
                Es Administrador
            </label>

            <div class="acciones">
                <button type="submit">Guardar</button>
                <button type="button" id="btnCancelar">Cancelar</button>
            </div>

        </form>
    </div>
</div>

<script src="/js/breadcrums.js"></script> 
<script src="/js/perfil.js"></script>

</body>
</html>