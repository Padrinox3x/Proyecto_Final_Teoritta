<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Permisos por Perfil</title>

<link rel="stylesheet" href="/css/permisosperfil.css">
<link rel="stylesheet" href="/css/breadcrums.css"> 

</head>
<body>

<%- include('partials/breadcrumb') %>

<div class="container">

<!-- 🔥 TOP BAR -->
<div class="top-bar">
    <input type="text" id="search" placeholder="Buscar módulo...">
    
    <select id="rows">
        <option value="5">5</option>
        <option value="10" selected>10</option>
        <option value="15">15</option>
    </select>

    <select id="perfilSelect"></select>
</div>

<table>
<thead>
<tr>
    <th>Módulo</th>
    <th>Agregar</th>
    <th>Editar</th>
    <th>Consultar</th>
    <th>Eliminar</th>
    <th>Detalle</th>
</tr>
</thead>
<tbody id="tablaPermisos"></tbody>
</table>

<!-- 🔥 PAGINACIÓN -->
<div class="pagination">
    <button onclick="firstPage()">⏮</button>
    <button onclick="prevPage()">◀</button>
    
    <span id="pageInfo"></span>
    
    <button onclick="nextPage()">▶</button>
    <button onclick="lastPage()">⏭</button>
</div>

<div style="padding:10px;">
    <button id="btnGuardar">💾 Guardar Cambios</button>
</div>

</div>

<script src="/js/breadcrums.js"></script> 
<script src="/js/permisosPerfil.js"></script>

<script>
let page = 1;
let rows = 10;

/* 🔥 OBTENER FILAS ACTUALES */
function getTableData(){
    return Array.from(document.querySelectorAll("#tablaPermisos tr"));
}

/* 🔍 FILTRO */
function filterData(){
    let search = document.getElementById("search").value.toLowerCase();
    let rows = getTableData();

    return rows.filter(row => 
        row.innerText.toLowerCase().includes(search)
    );
}

/* 📄 TOTAL PÁGINAS */
function totalPages(dataLength){
    return Math.ceil(dataLength / rows) || 1;
}

/* 🎨 RENDER PAGINADO */
function renderTable(){
    let allRows = getTableData();
    let filtered = filterData();

    // ocultar todas
    allRows.forEach(r => r.style.display = "none");

    let start = (page-1)*rows;
    let paginated = filtered.slice(start, start+rows);

    paginated.forEach(r => r.style.display = "");

    let total = totalPages(filtered.length);
    if(page > total) page = total;

    document.getElementById("pageInfo").innerText =
        "Página " + page + " de " + total;
}

/* ⏭ PAGINACIÓN */
function nextPage(){
    let total = totalPages(filterData().length);
    if(page < total){
        page++;
        renderTable();
    }
}

function prevPage(){
    if(page > 1){
        page--;
        renderTable();
    }
}

function firstPage(){
    page = 1;
    renderTable();
}

function lastPage(){
    page = totalPages(filterData().length);
    renderTable();
}

/* 🎛 EVENTOS */
document.getElementById("rows").addEventListener("change", e=>{
    rows = parseInt(e.target.value);
    page = 1;
    renderTable();
});

document.getElementById("search").addEventListener("input", ()=>{
    page = 1;
    renderTable();
});

/* ⏳ ESPERAR A QUE SE LLENE LA TABLA */
const observer = new MutationObserver(() => {
    renderTable();
});

observer.observe(document.getElementById("tablaPermisos"), {
    childList: true
});
</script>

</body>
</html>